{
	"name": "@remit/mailbox-service",
	"version": "1.0.0",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../.test.env --import tsx --test 'src/**/*.test.ts'",
		"test:integ": "RUN_INTEG_TESTS=1 node --env-file=../../.test.env --import tsx --test 'src/**/*.integ.test.ts'",
		"test:e2e": "RUN_E2E_TESTS=1 node --env-file=../../.e2e.env --import tsx --test-concurrency=1 --test 'src/**/*.e2e.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"devDependencies": {
		"@aws-sdk/client-dynamodb": "*",
		"@aws-sdk/client-sqs": "*",
		"@aws-sdk/lib-dynamodb": "*",
		"@remit/electrodb-entities": "*",
		"@remit/domain-enums": "*",
		"@remit/secrets-service": "*",
		"@remit/storage-service": "*",
		"@types/mailparser": "*",
		"@types/nodemailer": "*",
		"@types/stopword": "^2.0.3",
		"@types/uuid": "^10.0.0",
		"electrodb": "*",
		"expect-env": "*",
		"franc": "*",
		"natural": "^8.1.1",
		"short-uuid": "*",
		"stopword": "*"
	},
	"dependencies": {
		"imapflow": "^1.3.3",
		"mailparser": "^3.9.8",
		"nodemailer": "^8.0.5",
		"p-map": "^7.0.4"
	}
}
