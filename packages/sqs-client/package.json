{
	"name": "@remit/sqs-client",
	"version": "0.0.1",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./poller": {
			"types": "./src/poller.ts",
			"default": "./src/poller.ts"
		},
		"./producer": {
			"types": "./src/producer.ts",
			"default": "./src/producer.ts"
		}
	},
	"scripts": {
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../localhost-test-unit.env --test 'src/**/*.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"devDependencies": {
		"@aws-sdk/client-sqs": "*",
		"@aws-sdk/core": "*",
		"@types/aws-lambda": "*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remit-mail/reader.git",
		"directory": "packages/sqs-client"
	}
}
