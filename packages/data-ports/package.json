{
	"name": "@remit/data-ports",
	"version": "0.0.1",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./conformance": {
			"types": "./src/conformance/index.ts",
			"default": "./src/conformance/index.ts"
		},
		"./errors": {
			"types": "./src/errors.ts",
			"default": "./src/errors.ts"
		},
		"./id": {
			"types": "./src/id.ts",
			"default": "./src/id.ts"
		},
		"./account-settings": {
			"types": "./src/account-settings.ts",
			"default": "./src/account-settings.ts"
		},
		"./wellknown": {
			"types": "./src/wellknown.ts",
			"default": "./src/wellknown.ts"
		},
		"./update-manifest": {
			"types": "./src/update-manifest.ts",
			"default": "./src/update-manifest.ts"
		}
	},
	"scripts": {
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --import tsx --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-exclude='src/**/*.test.tsx' --test-coverage-lines=85 --test 'src/**/*.test.ts'"
	},
	"dependencies": {
		"@remit/domain-enums": "*",
		"short-uuid": "*",
		"uuid": "*",
		"zod": "*",
		"@remit/api-zod-schemas": "*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remit-mail/reader.git",
		"directory": "packages/data-ports"
	}
}
