{
	"name": "@remit/search-index-worker",
	"version": "0.0.1",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./data-ports": {
			"types": "./src/data-ports.ts",
			"default": "./src/data-ports.ts"
		}
	},
	"scripts": {
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../localhost-test-unit.env --import tsx --test 'src/**/*.test.ts'",
		"test:integ": "RUN_INTEG_TESTS=1 node --env-file=../../localhost-test-unit.env --import tsx --test 'src/**/*.integ.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"dependencies": {
		"@remit/outbox-relay": "*",
		"p-map": "*",
		"pg": "^8.0.0",
		"@remit/logger-lambda": "*",
		"@remit/sqs-client": "*",
		"@remit/data-ports": "*",
		"@remit/drizzle-service": "*",
		"@remit/search-service": "*",
		"@remit/storage-service": "*",
		"@aws-sdk/client-sqs": "*",
		"better-sqlite3": "^12.11.1",
		"drizzle-orm": "^0.45.2",
		"expect-env": "*",
		"@types/aws-lambda": "*",
		"@types/pg": "^8.0.0"
	},
	"devDependencies": {
		"@aws-sdk/client-dynamodb": "*",
		"@aws-sdk/core": "*",
		"@aws-sdk/lib-dynamodb": "*",
		"tsx": "*",
		"zod": "*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remit-mail/reader.git",
		"directory": "packages/search-index-worker"
	}
}
