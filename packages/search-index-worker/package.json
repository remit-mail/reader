{
	"name": "@remit/search-index-worker",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"bundle": "esbuild src/index.ts --sourcemap --bundle --platform=node --format=esm --outfile=dist/index.js",
		"test:typecheck": "tsc --noEmit",
		"test:run": "node --import tsx --test 'src/**/*.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"devDependencies": {
		"@aws-sdk/client-sqs": "*",
		"@remit/remit-electrodb-service": "*",
		"@remit/remit-logger-lambda": "*",
		"@remit/search-service": "*",
		"@remit/storage-service": "*",
		"@types/aws-lambda": "*",
		"esbuild": "*",
		"p-map": "*"
	}
}
