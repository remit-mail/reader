{
	"name": "@remit/search-index-worker",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../localhost-test-unit.env --import tsx --test 'src/**/*.test.ts'",
		"test:integ": "RUN_INTEG_TESTS=1 node --env-file=../../localhost-test-unit.env --import tsx --test 'src/**/*.integ.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"dependencies": {
		"@remit/remit-outbox-relay": "*",
		"p-map": "*",
		"pg": "^8.0.0"
	},
	"devDependencies": {
		"@aws-sdk/client-dynamodb": "*",
		"@aws-sdk/client-sqs": "*",
		"@aws-sdk/core": "*",
		"@aws-sdk/lib-dynamodb": "*",
		"@remit/data-ports": "*",
		"@remit/drizzle-service": "*",
		"better-sqlite3": "^12.11.1",
		"@remit/remit-electrodb-service": "*",
		"@remit/remit-logger-lambda": "*",
		"@remit/search-service": "*",
		"@remit/sqs-client": "*",
		"@remit/storage-service": "*",
		"@types/aws-lambda": "*",
		"@types/pg": "^8.0.0",
		"expect-env": "*",
		"tsx": "*",
		"zod": "*"
	}
}
