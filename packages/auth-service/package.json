{
  "name": "@remit/auth-service",
  "version": "0.0.1",
  "description": "better-auth identity service for the Postgres-parity stack (pg-parity)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./edge-tls": {
      "types": "./src/edge-tls.ts",
      "default": "./src/edge-tls.ts"
    },
    "./verifier": {
      "types": "./src/verifier.ts",
      "default": "./src/verifier.ts"
    }
  },
  "scripts": {
    "test:typecheck": "tsgo --noEmit -p tsconfig.json",
    "test:run": "node --import tsx --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-exclude='src/**/*.test.tsx' --test-coverage-lines=75 --test 'src/**/*.test.ts'",
    "test": "npm run test:typecheck && npm run test:run",
    "auth:schema:generate": "npx @better-auth/cli generate --config src/auth.gen.ts --output src/schema/auth-schema.ts -y",
    "auth:schema:push": "npx drizzle-kit push",
    "fix": "biome check --write src"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "drizzle-kit": "^0.31.1",
    "embedded-postgres": "^18.4.0-beta.17",
    "tsx": "*"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "pg": "^8.0.0",
    "@types/better-sqlite3": "^7.6.13"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remit-mail/reader.git",
    "directory": "packages/auth-service"
  }
}
