{
  "name": "@remit/web-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:routes": "node scripts/generate-routes.mjs",
    "build": "npm run generate:routes && tsc -b && vite build",
    "preview": "vite preview",
    "test:typecheck": "npm run generate:routes && tsgo --noEmit",
    "test:run": "node --import tsx --import ./test-support/register.mjs --test 'src/**/*.test.ts'",
    "test": "npm run test:typecheck && npm run test:run",
    "test:smoke:pg": "npx playwright test --config playwright.smoke.pg.config.ts",
    "test:e2e:pg": "npx playwright test --config playwright.e2e.pg.config.ts",
    "playwright:install": "npx playwright install chromium"
  },
  "devDependencies": {
    "@aws-amplify/ui-react": "^6",
    "@aws-sdk/client-dynamodb": "*",
    "@aws-sdk/client-sqs": "*",
    "@aws-sdk/lib-dynamodb": "*",
    "@types/nodemailer": "*",
    "nodemailer": "^9.0.3",
    "@hookform/resolvers": "*",
    "@platejs/autoformat": "*",
    "@platejs/basic-nodes": "*",
    "@platejs/link": "*",
    "@playwright/test": "1.58.2",
    "@remit/api-http-client": "file:../../build/remit-client",
    "@remit/electrodb-entities": "*",
    "@remit/drizzle-service": "*",
    "@remit/domain-enums": "*",
    "@remit/secrets-service": "*",
    "@remit/ui": "*",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5",
    "@tanstack/react-query-devtools": "^5",
    "@tanstack/react-router": "^1",
    "@tanstack/router-generator": "^1",
    "@tanstack/router-plugin": "^1",
    "@tanstack/zod-adapter": "^1",
    "@types/dompurify": "*",
    "@types/pngjs": "^6.0.5",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "aws-amplify": "^6",
    "clsx": "^2",
    "dompurify": "^3.4.7",
    "electrodb": "*",
    "expect-env": "*",
    "i18next": "^24",
    "i18next-browser-languagedetector": "^8",
    "i18next-http-backend": "^3.0.6",
    "lucide-react": "^0.468",
    "p-map": "*",
    "platejs": "*",
    "pngjs": "^5",
    "react": "^19",
    "react-dom": "^19.2.4",
    "react-hook-form": "*",
    "react-i18next": "^15",
    "tailwind-merge": "^2",
    "tailwindcss": "^4",
    "typescript": "*",
    "vite": "^7.3.6",
    "zod": "^3"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "aws-rum-web": "^3",
    "better-auth": "^1.6.23",
    "prop-types": "^15.8.1",
    "react-resizable-panels": "^2.1.9",
    "vaul": "^1.1.2"
  }
}
