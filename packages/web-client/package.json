{
  "name": "@remit/web-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:typecheck": "test -f src/routeTree.gen.ts || vite build > /dev/null 2>&1; tsc --noEmit",
    "test:run": "node --import tsx --test 'src/**/*.test.ts'",
    "test": "npm run test:typecheck && npm run test:run",
    "test:smoke": "npx playwright test --config playwright.smoke.config.ts",
    "test:smoke:ui": "npx playwright test --config playwright.smoke.config.ts --ui",
    "test:e2e": "npx playwright test --config playwright.e2e.config.ts",
    "test:e2e:ui": "npx playwright test --config playwright.e2e.config.ts --ui",
    "playwright:install": "npx playwright install chromium"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "*",
    "@aws-sdk/client-sqs": "*",
    "@aws-sdk/lib-dynamodb": "*",
    "@hookform/resolvers": "*",
    "@platejs/autoformat": "*",
    "@platejs/basic-nodes": "*",
    "@platejs/link": "*",
    "@playwright/test": "^1",
    "@remit/api-http-client": "file:../../build/remit-client",
    "@remit/electrodb-entities": "*",
    "@remit/remit-electrodb-service": "*",
    "@remit/domain-enums": "*",
    "@remit/secrets-service": "*",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5",
    "@tanstack/react-query-devtools": "^5",
    "@tanstack/react-router": "^1",
    "@tanstack/router-plugin": "^1",
    "@tanstack/zod-adapter": "^1",
    "@types/dompurify": "*",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "clsx": "^2",
    "dompurify": "*",
    "electrodb": "*",
    "expect-env": "*",
    "i18next": "^24",
    "i18next-browser-languagedetector": "^8",
    "i18next-http-backend": "^3",
    "lucide-react": "^0.468",
    "platejs": "*",
    "react": "^19",
    "react-dom": "^19.2.4",
    "react-hook-form": "*",
    "react-i18next": "^15",
    "tailwind-merge": "^2",
    "tailwindcss": "^4",
    "typescript": "*",
    "vite": "^6",
    "zod": "^3"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "react-resizable-panels": "^2.1.7",
    "sonner": "^2.0.7"
  }
}
