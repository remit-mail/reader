# Remit web client — Vite environment variables
#
# Copy this file to .env.local and fill in the values for local dev.
# CI injects these from SSM at build time (see .github/workflows/deploy.yml).
#
# If VITE_COGNITO_USER_POOL_ID is missing, the app runs in local dev mode
# without auth and shows a banner.

# Cognito user pool ID (from SSM: /${stage}/Remit/cognitoUserPoolId)
VITE_COGNITO_USER_POOL_ID=

# Cognito app client ID for the browser SPA (from SSM: /${stage}/Remit/cognitoBrowserClientId)
VITE_COGNITO_CLIENT_ID=

# Cognito hosted UI domain (from SSM: /${stage}/Remit/cognitoDomain)
# Optional — only needed for OAuth hosted UI flow
VITE_COGNITO_DOMAIN=

# AWS region hosting the user pool
VITE_COGNITO_REGION=eu-west-1

# Base URL of the deployed API (from SSM: /${stage}/Remit/apiUrl)
VITE_API_URL=

# Origin where the SPA is served (from SSM: /${stage}/Remit/frontendUrl)
# Used as the OAuth redirect URI. Do NOT use window.location.origin at runtime —
# the production bundle carries this value as a string literal.
VITE_APP_ORIGIN=

# better-auth (Postgres-parity / Scaleway stack). Set to 1 to use better-auth
# instead of Cognito. Leave unset for the AWS/Cognito path.
# VITE_BETTER_AUTH_ENABLED=

# CloudWatch RUM — injected at deploy time; leave blank for local dev (telemetry becomes a no-op).
# VITE_RUM_APP_MONITOR_ID=
# VITE_RUM_IDENTITY_POOL_ID=
# VITE_AWS_REGION=eu-west-1
