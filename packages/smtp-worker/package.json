{
	"name": "@remit/smtp-worker",
	"version": "0.0.1",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./data-ports": {
			"types": "./src/data-ports.ts",
			"default": "./src/data-ports.ts"
		}
	},
	"scripts": {
		"bundle": "node build.mjs",
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../localhost-test-unit.env --test 'src/**/*.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"dependencies": {
		"@remit/data-ports": "*",
		"@remit/drizzle-service": "*",
		"@remit/logger-lambda": "*",
		"@remit/sqs-client": "*",
		"@remit/secrets-service": "*",
		"@remit/smtp-service": "*",
		"@remit/domain-enums": "*",
		"@remit/mail-oauth-service": "*",
		"@remit/mailbox-service": "*"
	},
	"devDependencies": {
		"@aws-sdk/client-sqs": "*",
		"@aws-sdk/core": "*",
		"@remit/storage-service": "*",
		"@types/aws-lambda": "*",
		"@types/pg": "^8.0.0",
		"esbuild": "^0.27.7",
		"expect-env": "*",
		"p-map": "*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remit-mail/reader.git",
		"directory": "packages/smtp-worker"
	}
}
