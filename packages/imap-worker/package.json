{
	"name": "@remit/imap-worker",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"remit-worker": "./dist/cli.js"
	},
	"scripts": {
		"bundle": "esbuild src/index.ts --sourcemap --bundle --platform=node --format=esm --outfile=dist/index.js",
		"cli": "node --env-file=../../.localhost.env src/cli.ts",
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../.test.env --test 'src/**/*.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"devDependencies": {
		"@aws-sdk/client-sqs": "*",
		"@aws-sdk/core": "*",
		"@remit/domain-enums": "*",
		"@remit/logger-lambda": "*",
		"@remit/mail-oauth-service": "*",
		"@remit/mailbox-service": "*",
		"@remit/search-index-worker": "*",
		"@remit/secrets-service": "*",
		"@remit/storage-service": "*",
		"@types/aws-lambda": "*",
		"@types/nodemailer": "*",
		"esbuild": "^0.27.7",
		"expect-env": "*",
		"p-map": "*"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1055.0",
		"nodemailer": "^8.0.5"
	}
}
