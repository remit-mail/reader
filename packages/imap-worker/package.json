{
	"name": "@remit/imap-worker",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"remit-worker": "./dist/cli.js"
	},
	"scripts": {
		"build": "node build.mjs",
		"cli": "NODE_ENV=development node --import tsx src/cli.ts",
		"test:typecheck": "tsc --noEmit",
		"test:run": "node --import tsx --test 'src/**/*.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"devDependencies": {
		"@aws-sdk/client-sqs": "*",
		"@remit/remit-electrodb-service": "*",
		"@remit/mailbox-service": "*",
		"@remit/secrets-service": "*",
		"@remit/remit-logger-lambda": "*",
		"@types/aws-lambda": "*",
		"esbuild": "*",
		"expect-env": "*"
	}
}
