{
	"name": "@remit/account-worker",
	"version": "0.0.1",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./cascade": {
			"types": "./src/cascade.ts",
			"default": "./src/cascade.ts"
		},
		"./deletion-capabilities": {
			"types": "./src/deletion-capabilities.ts",
			"default": "./src/deletion-capabilities.ts"
		},
		"./fanout": {
			"types": "./src/handlers/account-fanout.ts",
			"default": "./src/handlers/account-fanout.ts"
		},
		"./finalize": {
			"types": "./src/handlers/account-finalize.ts",
			"default": "./src/handlers/account-finalize.ts"
		}
	},
	"scripts": {
		"bundle": "esbuild src/index.ts --sourcemap --bundle --platform=node --format=esm --outfile=dist/index.js",
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../localhost-test-unit.env --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-exclude='src/**/*.test.tsx' --test-coverage-lines=50 --test 'src/**/*.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"dependencies": {
		"@remit/data-ports": "*",
		"@remit/logger-lambda": "*",
		"@remit/drizzle-service": "*",
		"@remit/backend": "*",
		"@remit/sqs-client": "*",
		"@remit/storage-service": "*",
		"@remit/electrodb-entities": "*",
		"@remit/search-index-worker": "*",
		"@aws-sdk/client-sqs": "*",
		"archiver": "*",
		"electrodb": "*",
		"expect-env": "*",
		"@types/archiver": "*",
		"@types/aws-lambda": "*"
	},
	"devDependencies": {
		"@aws-sdk/client-cloudfront": "*",
		"@aws-sdk/client-cognito-identity-provider": "*",
		"@aws-sdk/client-dynamodb": "*",
		"@aws-sdk/client-s3": "*",
		"@aws-sdk/core": "*",
		"@aws-sdk/lib-dynamodb": "*",
		"@aws-sdk/lib-storage": "*",
		"@aws-sdk/s3-request-presigner": "*",
		"@remit/domain-enums": "*",
		"@remit/search-service": "*",
		"aws-sdk-client-mock": "*",
		"esbuild": "^0.27.7",
		"p-map": "*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remit-mail/reader.git",
		"directory": "packages/account-worker"
	}
}
