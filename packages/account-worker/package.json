		"@aws-sdk/lib-dynamodb": "*",
		"@remit/electrodb-entities": "*",
		"@remit/logger-lambda": "*",
		"@remit/search-index-worker": "*",
		"@types/aws-lambda": "*",
		"aws-sdk-client-mock": "*",
		"electrodb": "*",
		"esbuild": "^0.27.7",
		"expect-env": "*",
		"p-map": "*"
	}
}
