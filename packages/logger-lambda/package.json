{
	"name": "@remit/logger-lambda",
	"version": "0.0.1",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --experimental-test-module-mocks --import tsx --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-exclude='src/**/*.test.tsx' --test-coverage-lines=70 --test 'src/**/*.test.ts'",
		"test": "npm run test:typecheck && npm run test:run",
		"build": "npm run test:typecheck"
	},
	"dependencies": {
		"@aws-lambda-powertools/logger": "^2",
		"@aws-lambda-powertools/metrics": "^2",
		"@types/aws-lambda": "*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remit-mail/reader.git",
		"directory": "packages/logger-lambda"
	}
}
