{
	"name": "@remit/search-service",
	"version": "0.0.1",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./from-env": {
			"types": "./src/from-env.ts",
			"default": "./src/from-env.ts"
		},
		"./s3-vectors": {
			"types": "./src/s3-vectors.ts",
			"default": "./src/s3-vectors.ts"
		},
		"./bedrock": {
			"types": "./src/bedrock.ts",
			"default": "./src/bedrock.ts"
		},
		"./sqlite-vec": {
			"types": "./src/sqlite-vec.ts",
			"default": "./src/sqlite-vec.ts"
		},
		"./pgvector": {
			"types": "./src/pgvector.ts",
			"default": "./src/pgvector.ts"
		}
	},
	"scripts": {
		"test:typecheck": "tsgo --noEmit",
		"test:run": "node --env-file=../../localhost-test-unit.env --import tsx --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-exclude='src/**/*.test.tsx' --test-coverage-lines=70 --test 'src/**/*.test.ts'",
		"test:integ": "RUN_INTEG_TESTS=1 node --env-file=../../localhost-test-unit.env --import tsx --test 'src/**/*.integ.test.ts'",
		"test": "npm run test:typecheck && npm run test:run"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.2.0",
		"@remit/domain-enums": "*",
		"@remit/api-openapi-types": "*",
		"better-sqlite3": "^12.11.1",
		"p-limit": "^6.2.0",
		"pg": "^8.0.0",
		"sqlite-vec": "^0.1.9",
		"zod": "*",
		"@aws-sdk/client-bedrock-runtime": "*",
		"@aws-sdk/client-s3vectors": "*",
		"@smithy/types": "^4.16.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/pg": "^8.20.0"
	},
	"devDependencies": {
		"@remit/storage-service": "*",
		"aws-sdk-client-mock": "*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remit-mail/reader.git",
		"directory": "packages/search-service"
	}
}
