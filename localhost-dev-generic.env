# Env for the one-command local Postgres + better-auth dev stack (docker compose).
# The "dev-generic" leg of the {dev,test} x {aws,generic} env convention: generic
# = the Postgres + better-auth stack. Serves the local remit_dev database on ports
# 4123 (web) / 4124 (backend), a range no test/e2e/playwright/mokapi config uses.
#
# Every value here is a local-dev throwaway: the DB creds are the local postgres
# container's own credentials, BETTER_AUTH_SECRET signs JWTs only against the
# local DB, and the AWS/KMS values are fakes. No cross-environment secret lives
# here — real login passwords are hashed in the DB, not in this file.
#
# No LOCAL_ACCOUNT_CONFIG_ID here on purpose: identity comes from better-auth
# login, not an auth bypass.
#
# App containers run with host networking, so every host is localhost — the same
# wiring the pm2 dev stack uses.

DATA_BACKEND=postgres
SERVER_PORT=4124
# Unused in postgres mode, but the dev-server startup banner prints them and
# expect-env throws on any missing var.
DYNAMODB_PORT=5434
DYNAMODB_TABLE_NAME=remit-local
DYNAMODB_PERSIST=true
NODE_ENV=development
NODE_NO_WARNINGS=1
HOME=/tmp
NODE_TLS_REJECT_UNAUTHORIZED=0

# Postgres — local remit_dev database (the pgdata named volume)
PG_CONNECTION_URL=postgresql://remit:remit@localhost:5432/remit_dev

# better-auth (local identity)
BETTER_AUTH_URL=http://devbox:4124
BETTER_AUTH_SECRET=dev-better-auth-secret-at-least-32-chars-long
BETTER_AUTH_JWKS_URL=http://localhost:4124/api/auth/jwks
BETTER_AUTH_TRUSTED_ORIGINS=http://devbox:4123,http://localhost:4123

# Web origin / body content delivery
CONTENT_DELIVERY_DOMAIN=http://devbox:4123
CORS_ALLOWED_ORIGINS=http://devbox:4123,http://localhost:4123

# KMS / AWS local fakes
KMS_KEY_ID=FAKE_KMS_KEY_ID
FAKE_KMS_DATAKEY=8AD6A6C8-B5E2-488F-B017-96B662DC01AC
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=not-a-region

# SQS (elasticmq)
SQS_QUEUE_URL=http://localhost:9324/000000000000/remit-local
SQS_QUEUE_URL_MAILBOXES=http://localhost:9324/000000000000/remit-mailboxes.fifo
SQS_QUEUE_URL_MESSAGES=http://localhost:9324/000000000000/remit-messages.fifo
SQS_QUEUE_URL_FLAGS=http://localhost:9324/000000000000/remit-flags.fifo
SQS_QUEUE_URL_BODY=http://localhost:9324/000000000000/remit-body
SQS_QUEUE_URL_MAILBOX_MGMT=http://localhost:9324/000000000000/remit-mailbox-mgmt
SQS_QUEUE_URL_MESSAGE_MGMT=http://localhost:9324/000000000000/remit-message-mgmt
SQS_QUEUE_URL_SEARCH_INDEX=http://localhost:9324/000000000000/remit-search-index
SQS_QUEUE_URL_ATTACHMENT_SCAN=http://localhost:9324/000000000000/remit-attachment-scan
WORKER_MAX_CONCURRENCY=3
WORKER_MAX_CONCURRENCY_BODY=1
BODY_SYNC_CONCURRENCY=3
BODY_SYNC_ENABLED_PARAMETER_NAME=/development/Remit/bodySyncEnabled

# Periodic mailbox-sync scheduler (#1247) — read by the scheduler service
# above (local-runner.ts) and, in production, by the EventBridge-scheduled
# Lambda. Same defaults as infra/lib/config.ts's `mailboxSync` stage config;
# shortened here so a local session actually observes an offline-tier sync.
MAILBOX_SYNC_ONLINE_INTERVAL_SECONDS=300
MAILBOX_SYNC_OFFLINE_INTERVAL_SECONDS=600

# Local storage + semantic search (relative to the bind-mounted worktree)
STORAGE_LOCAL_PATH=.remit/storage
LOCAL_VECTORDB_PATH=.remit/vectors.sqlite
SEARCH_EMBEDDING_PROVIDER=local
SEARCH_EMBEDDING_MODEL_ID=Xenova/paraphrase-multilingual-MiniLM-L12-v2
SEARCH_EMBEDDING_DIMENSIONS=384

# Vite (web)
VITE_PROXY_BACKEND_PORT=4124
VITE_BETTER_AUTH_ENABLED=1
