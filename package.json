{
  "name": "reader",
  "version": "0.1.0",
  "private": true,
  "description": "An email client you run yourself.",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "patch-package --error-on-fail --error-on-warn",
    "codegen": "make",
    "codegen:openapi": "tsp compile ./typespec",
    "codegen:sqlite": "tsp compile ./typespec --config ./typespec/tspconfig.sqlite.yaml",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run test:typecheck --workspaces --if-present",
    "test": "npm run test:run --workspaces --if-present",
    "build-storybook": "npm run build-storybook -w @remit/workbench",
    "lint": "biome ci",
    "format": "biome check --fix && tsp format ./typespec",
    "release": "node npm-scripts/publish-packages.mjs",
    "release:dry-run": "node npm-scripts/publish-packages.mjs --dry-run",
    "check:publish-closure": "node npm-scripts/check-publish-closure.mjs",
    "check:consumer-typecheck": "node npm-scripts/check-consumer-typecheck.mjs",
    "check:web-client-consumer": "node npm-scripts/check-web-client-consumer.mjs",
    "check:patches-applied": "node npm-scripts/check-patches-applied.mjs",
    "check:ci-coverage": "node npm-scripts/check-ci-coverage.mjs",
    "bootstrap:publish-metadata": "node npm-scripts/set-publish-metadata.mjs",
    "images:publish": "bash npm-scripts/images-publish.sh",
    "release:tag": "bash npm-scripts/release-tag.sh",
    "release:check-tag": "bash npm-scripts/release-check-tag.sh",
    "release:check-annotation": "bash npm-scripts/release-check-annotation.sh",
    "test:scripts": "node npm-scripts/test-script-suites.mjs",
    "manifest:write": "node npm-scripts/write-update-manifest.mjs",
    "manifest:copy-to-pages": "bash npm-scripts/copy-update-manifest.sh",
    "coverage:audit": "node npm-scripts/coverage-audit.mjs",
    "test:ci": "node npm-scripts/test-parallel.mjs",
    "e2e": "npm run e2e:up && npm run e2e:test; status=$?; npm run e2e:down; exit $status",
    "e2e:up": "bash npm-scripts/e2e-up.sh",
    "e2e:test": "bash npm-scripts/e2e-test.sh",
    "e2e:logs": "bash npm-scripts/e2e-logs.sh",
    "e2e:down": "bash npm-scripts/e2e-down.sh",
    "e2e:dev": "npm run e2e:dev:up && npm run e2e:test; status=$?; npm run e2e:dev:down; exit $status",
    "e2e:dev:up": "bash npm-scripts/e2e-dev-up.sh",
    "e2e:dev:logs": "bash npm-scripts/e2e-dev-logs.sh",
    "e2e:dev:down": "bash npm-scripts/e2e-dev-down.sh",
    "e2e:dev:migrate": "node npm-scripts/docker-bundle.mjs backend-migrate && cd deploy/vps && node ../../dist-docker/backend/migrate.mjs"
  },
  "dependencies": {
    "@remit/api-http-client": "file:build/remit-client",
    "@remit/drizzle-pg-schema": "file:build/drizzle-entities",
    "@remit/drizzle-sqlite-schema": "file:build/drizzle-entities-sqlite"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@hey-api/openapi-ts": "^0.90.10",
    "@kattebak/typespec-drizzle-orm-generator": "^3.8.3",
    "@kattebak/typespec-enum-emitter": "^1.2.2",
    "@kattebak/typespec-openapi-types-emitter": "^1.0.0",
    "@kattebak/typespec-zod-emitter": "^2.0.3",
    "@remit/api-openapi-types": "file:build/openapi-types",
    "@remit/api-zod-schemas": "file:build/zod-schemas",
    "@remit/domain-enums": "file:build/ts-enums",
    "@remit/electrodb-entities": "file:build/ddb-entities",
    "@tanstack/react-query": "^5.90.20",
    "@typescript/native-preview": "7.0.0-dev.20260505.1",
    "@typespec/compiler": "~1.8.0",
    "@typespec/http": "~1.8.0",
    "@typespec/openapi": "~1.8.0",
    "@typespec/openapi3": "~1.8.0",
    "drizzle-orm": "0.45.2",
    "patch-package": "^8.0.1",
    "short-uuid": "^6.0.3",
    "tsx": "^4",
    "typescript": "^5.9.3",
    "typespec-electrodb-emitter": "^3.2.2"
  }
}
