{
  "name": "reader",
  "version": "0.1.0",
  "private": true,
  "description": "An email client you run yourself.",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "codegen": "tsp compile ./typespec",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "biome ci",
    "format": "biome check --fix && tsp format ./typespec"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@typespec/compiler": "~1.8.0",
    "@typespec/http": "~1.8.0",
    "@typespec/openapi": "~1.8.0",
    "@typespec/openapi3": "~1.8.0",
    "tsx": "^4",
    "typescript": "^5.9.3"
  }
}
