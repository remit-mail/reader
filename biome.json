{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"plugins": [
		"./plugins/no-logger-info.grit",
		"./plugins/no-silent-catch.grit"
	],
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.mjs"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.js",
			"**/*.mjs",
			"!**/routeTree.gen.ts"
		],
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedPrivateClassMembers": "off"
			},
			"style": {
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"filenameCases": ["kebab-case", "PascalCase", "camelCase"]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
