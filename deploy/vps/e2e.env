# Configuration for the black-box e2e stack. `npm run e2e:up` copies this to
# `.env` next to the compose files, which is where both compose variable
# interpolation and every service's `env_file` read it from.
#
# Nothing here is secret. The stack it configures binds to loopback only, holds
# no real mail, and is destroyed by `npm run e2e:down`. These values are fixed
# on purpose: a run is reproducible, and a failure is reproducible from the
# same file. Do not copy this into a real deployment — start from
# remit.env.template and generate your own secrets.

REMIT_TAG=latest

# -----------------------------------------------------------------------
# Edge and origin
# -----------------------------------------------------------------------
# Caddy is published on loopback (docker-compose.e2e.yml). PUBLIC_ORIGIN must
# name the address the browser actually loads, port included — better-auth
# rejects a sign-in whose Origin is not in its trusted set.
TLS_MODE=off
E2E_HTTP_PORT=18080
PUBLIC_ORIGIN=http://localhost:18080

# -----------------------------------------------------------------------
# Dovecot
# -----------------------------------------------------------------------
# The app reaches the server as `dovecot:143` on the compose network; the suite
# APPENDs to it through the published loopback port.
#
# There is no username here on purpose: each run mints its own, and Dovecot
# accepts any username with this password and gives it an empty maildir. That is
# what keeps a reused stack from letting a previous run's mail satisfy this
# run's assertions.
E2E_IMAP_HOST=dovecot
E2E_IMAP_PORT=11143
E2E_IMAP_PASSWORD=e2e-imap-password

# -----------------------------------------------------------------------
# Auth and credential encryption
# -----------------------------------------------------------------------
BETTER_AUTH_SECRET=e2e-better-auth-secret-not-a-secret-32chars
BETTER_AUTH_JWKS_URL=http://backend:8080/api/auth/jwks
KMS_KEY_ID=FAKE_KMS_KEY_ID
FAKE_KMS_DATAKEY=8AD6A6C8B5E2488FB01796B662DC01AC8AD6A6C8B5E2488FB01796B662DC01AC

# -----------------------------------------------------------------------
# Storage and search
# -----------------------------------------------------------------------
STORAGE_LOCAL_PATH=/data/storage
SEARCH_EMBEDDING_PROVIDER=local
SEARCH_EMBEDDING_MODEL_ID=Xenova/paraphrase-multilingual-MiniLM-L12-v2
SEARCH_EMBEDDING_DIMENSIONS=384

# -----------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------
# The compose file pins DATA_BACKEND=sqlite and both database paths; this value
# is only here because the startup banner reads it.
DATA_BACKEND=sqlite
NODE_ENV=production
NODE_NO_WARNINGS=1
DYNAMODB_PORT=5434
DYNAMODB_TABLE_NAME=unused-in-sqlite-mode
POSTGRES_PASSWORD=unused-in-sqlite-mode
PG_CONNECTION_URL=postgresql://remit:unused@postgres:5432/remit

# -----------------------------------------------------------------------
# Queues
# -----------------------------------------------------------------------
SQS_QUEUE_URL_MAILBOXES=http://queue:9324/000000000000/remit-mailboxes.fifo
SQS_QUEUE_URL_MESSAGES=http://queue:9324/000000000000/remit-messages.fifo
SQS_QUEUE_URL_FLAGS=http://queue:9324/000000000000/remit-flags.fifo
SQS_QUEUE_URL_BODY=http://queue:9324/000000000000/remit-body
SQS_QUEUE_URL_MAILBOX_MGMT=http://queue:9324/000000000000/remit-mailbox-mgmt
SQS_QUEUE_URL_MESSAGE_MGMT=http://queue:9324/000000000000/remit-message-mgmt
SQS_QUEUE_URL_SEARCH_INDEX=http://queue:9324/000000000000/remit-search-index
SQS_QUEUE_URL_SMTP=http://queue:9324/000000000000/remit-smtp
SQS_QUEUE_URL=http://queue:9324/000000000000/remit-mailboxes.fifo
SQS_QUEUE_URL_ACCOUNT_FANOUT=http://queue:9324/000000000000/remit-account-fanout
SQS_QUEUE_URL_ACCOUNT_FINALIZE=http://queue:9324/000000000000/remit-account-finalize
SQS_QUEUE_URL_ACCOUNT_PURGE_DELETE=http://queue:9324/000000000000/remit-account-purge-delete.fifo
WORKER_MAX_CONCURRENCY=3
WORKER_MAX_CONCURRENCY_BODY=1
BODY_SYNC_CONCURRENCY=3
BODY_SYNC_ENABLED_PARAMETER_NAME=/self-host/Remit/bodySyncEnabled

# -----------------------------------------------------------------------
# AWS SDK placeholders — nothing in this stack talks to AWS.
# -----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=not-a-region
