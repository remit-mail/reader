#!/bin/sh
#
# remit — admin wrapper for the self-host docker compose deployment.
#
# Wraps `docker compose` against the deployment directory so the operator
# never has to cd there or repeat -f/--env-file. install.sh bakes the
# directory it installed to into DEFAULT_DIR below and the compose file it
# installed into DEFAULT_COMPOSE_FILE; $REMIT_DIR and $REMIT_COMPOSE_FILE
# override them.

set -eu

DEFAULT_DIR=/opt/remit
DEFAULT_COMPOSE_FILE=docker-compose.sqlite.yml
REMIT_DIR="${REMIT_DIR:-$DEFAULT_DIR}"
REMIT_COMPOSE_FILE="${REMIT_COMPOSE_FILE:-$DEFAULT_COMPOSE_FILE}"

PROG=remit

die() {
	printf '%s: %s\n' "$PROG" "$1" >&2
	exit 1
}

usage() {
	cat <<EOF
Usage: remit <command> [args]

  restart [--hard]     Start serving, applying any .env change. --hard stops
                       the stack first.
  logs [service...]    Follow logs (last 100 lines).
  status               Show services, the running tag, and the public origin.
  update [--tag TAG]   Pull images and apply them, then check the migration.
  down                 Stop serving: the site goes offline until 'remit
                       restart'. Accounts, mail and settings are untouched.
  purge --yes          Destroy the deployment: containers and every data
                       volume, accounts included. Without --yes it only says
                       what would go. Use 'down' to merely stop serving.
  config               Print the effective configuration, secrets redacted.
  cert                 Export Caddy's root CA to the current directory, so
                       browsers stop warning (TLS_MODE=internal only).
  help                 This message.

Deployment directory: $REMIT_DIR (override with \$REMIT_DIR)
Compose file:         $REMIT_COMPOSE_FILE (override with \$REMIT_COMPOSE_FILE)
EOF
}

compose() {
	docker compose \
		--project-directory "$REMIT_DIR" \
		-f "$REMIT_DIR/$REMIT_COMPOSE_FILE" \
		--env-file "$REMIT_DIR/.env" \
		"$@"
}

require_deployment() {
	[ -d "$REMIT_DIR" ] ||
		die "no deployment directory at $REMIT_DIR — set \$REMIT_DIR or run install.sh"
	[ -f "$REMIT_DIR/$REMIT_COMPOSE_FILE" ] ||
		die "$REMIT_DIR holds no $REMIT_COMPOSE_FILE.
The directory exists, so the deployment may be there under another compose
file name: set \$REMIT_COMPOSE_FILE to it. Otherwise \$REMIT_DIR points at the
wrong directory."
	[ -f "$REMIT_DIR/.env" ] ||
		die "no .env at $REMIT_DIR — set \$REMIT_DIR or run install.sh"
}

get_var() {
	_k=$1
	_k="$_k" awk '
		BEGIN { k = ENVIRON["_k"] }
		index($0, k "=") == 1 { print substr($0, length(k) + 2); exit }
	' "$REMIT_DIR/.env"
}

# The temp file holds FAKE_KMS_DATAKEY like the .env it replaces, so it is
# created under a 077 umask rather than chmod'd after the write: a chmod after
# the fact leaves the secrets world-readable for the length of the write.
set_var() {
	_k=$1
	_v=$2
	rm -f "$REMIT_DIR/.env.tmp"
	(
		umask 077
		_k="$_k" _v="$_v" awk '
			BEGIN { k = ENVIRON["_k"]; v = ENVIRON["_v"]; done = 0 }
			!done && index($0, k "=") == 1 { print k "=" v; done = 1; next }
			{ print }
			END { if (!done) print k "=" v }
		' "$REMIT_DIR/.env" >"$REMIT_DIR/.env.tmp"
	)
	mv "$REMIT_DIR/.env.tmp" "$REMIT_DIR/.env"
}

# Shared by `update` and by install.sh, which calls this wrapper rather than
# repeating the pull/up/migrate-gate sequence.
#
# The pull moves ~4 GB on a first install (search-index-worker alone is
# ~1.36 GB), so its progress is streamed rather than buffered for a diagnosis
# that is usually never needed — buffering makes a working install look hung
# for minutes. The copy kept on the side is only there to classify a failure,
# and the pull's own exit status has to be carried out of the pipeline by hand
# because the pipeline reports tee's.
pull_images() {
	_log=$(mktemp) || die "cannot create a temporary file for the pull log"
	_status=$(mktemp) || die "cannot create a temporary file for the pull status"
	# `|| _rc=$?` is what keeps set -e from killing the subshell before the
	# status is recorded; the status has to travel by file because the subshell
	# cannot assign to this one.
	{
		_rc=0
		compose pull 2>&1 || _rc=$?
		printf '%s' "$_rc" >"$_status"
	} | tee "$_log"
	_code=$(cat "$_status" 2>/dev/null || printf 1)
	rm -f "$_status"
	if [ "$_code" = "0" ]; then
		rm -f "$_log"
		return 0
	fi
	if grep -qiE 'denied|unauthorized|401|403' "$_log"; then
		rm -f "$_log"
		die "a registry refused the pull (see above).

This is not a missing token. Every image here pulls anonymously — the
ghcr.io/remit-mail/reader/* packages are public — so a refusal means a
credential was sent and rejected: an expired or revoked token left in
~/.docker/config.json by an earlier 'docker login' is offered instead of
pulling anonymously. Drop it and retry:

  docker logout ghcr.io       # or whichever registry the error names above
  remit update

Credentials are per-user, so a login done under sudo lives in root's config,
not yours. If neither is it, check whether the docker daemon is pointed at a
registry mirror or proxy fronting the registry above."
	fi
	rm -f "$_log"
	die "docker compose pull failed (see above)"
}

# migrate is a one-shot that every app service gates on
# (service_completed_successfully). If it fails, `up -d` reports a dependency
# error and the real cause is only in migrate's own logs.
check_migrate() {
	_cid=$(compose ps -aq migrate 2>/dev/null || true)
	if [ -z "$_cid" ]; then
		die "the migrate one-shot never ran — the stack is not usable"
	fi
	_code=$(docker inspect -f '{{.State.ExitCode}}' "$_cid" 2>/dev/null || echo 1)
	if [ "$_code" != "0" ]; then
		printf '\n--- migrate logs ---\n' >&2
		compose logs --no-log-prefix migrate >&2 2>/dev/null || true
		printf -- '--- end migrate logs ---\n\n' >&2
		die "the database migration failed (exit $_code). No app service starts until it succeeds."
	fi
}

apply() {
	if ! compose up -d; then
		check_migrate
		die "docker compose up failed (see above)"
	fi
	check_migrate
}

cmd_restart() {
	require_deployment
	if [ "${1:-}" = "--hard" ]; then
		compose stop
	elif [ -n "${1:-}" ]; then
		die "restart: unknown option '$1'"
	fi
	# up -d, never `compose restart`: restart reuses existing containers and
	# ignores .env changes, so config edits appear to apply but do not.
	apply
	report_serving
	printf 'Configuration in %s/.env is live.\n' "$REMIT_DIR"
}

cmd_logs() {
	require_deployment
	compose logs -f --tail=100 "$@"
}

# What the operator wants after a command that leaves the stack serving is the
# address, so it leads. A deployment part-way through configuration may not have
# one yet; that is not a reason to fail the command that just succeeded.
report_serving() {
	_origin=$(get_var PUBLIC_ORIGIN 2>/dev/null || true)
	[ -n "$_origin" ] || return 0
	printf 'Open %s\n' "$_origin"
}

cmd_status() {
	require_deployment
	printf 'Directory: %s\n' "$REMIT_DIR"
	printf 'Tag:       %s\n' "$(get_var REMIT_TAG)"
	printf 'Origin:    %s\n' "$(get_var PUBLIC_ORIGIN)"
	printf '\n'
	compose ps
}

cmd_update() {
	require_deployment
	_tag=""
	while [ $# -gt 0 ]; do
		case "$1" in
		--tag)
			[ $# -ge 2 ] || die "update: --tag needs a value"
			_tag=$2
			shift 2
			;;
		*) die "update: unknown option '$1'" ;;
		esac
	done
	# The tag reaches .env only once its images are on the box. Writing it
	# first leaves .env naming a version that failed to pull, which is then
	# what the next `up` — or the next operator reading it — believes is
	# running. Compose reads the exported value ahead of the .env one, so the
	# pull is already the new tag's.
	if [ -n "$_tag" ]; then
		REMIT_TAG=$_tag
		export REMIT_TAG
	fi
	pull_images
	if [ -n "$_tag" ]; then
		set_var REMIT_TAG "$_tag"
	fi
	apply
	printf '\n'
	report_serving
	printf 'Running tag %s.\n' "$(get_var REMIT_TAG)"
}

cmd_down() {
	require_deployment
	# stop, never `down`: the pgdata and message_storage volumes hold every
	# account, credential and message body on this box.
	compose stop
	printf "remit is stopped: %s serves nothing until 'remit restart'.\n" "$(get_var PUBLIC_ORIGIN)"
	printf "No data was removed — accounts, mail and settings come back with it.\n"
}

# The one destructive command. --yes is the confirmation: the wrapper has to
# work under `curl | bash`-style non-interactive use, so it never reads stdin.
cmd_purge() {
	require_deployment
	_yes=0
	while [ $# -gt 0 ]; do
		case "$1" in
		--yes)
			_yes=1
			shift
			;;
		*) die "purge: unknown option '$1'" ;;
		esac
	done
	if [ "$_yes" != "1" ]; then
		cat >&2 <<EOF
purge would destroy this deployment's data. Nothing has been touched.

It removes every container and network, and these volumes:

  sqlite_data      every account, message index, tag and setting
  message_storage  the cached message bodies
  queue_data       work still queued
  caddy_data       the TLS certificates, including the internal root CA
  caddy_config     caddy's own state

Your accounts and everything you have organised in the app are gone with
sqlite_data and do not come back. Message bodies do: they are a cache of IMAP,
which is the source of truth, so they re-sync once an account is added again.

The install directory is left alone, .env and its FAKE_KMS_DATAKEY included:
  $REMIT_DIR
So 'remit restart' afterwards brings up an empty but working stack.

To stop serving without destroying anything, use 'remit down'.
Run 'remit purge --yes' if this is what you want.
EOF
		exit 1
	fi
	compose down -v --remove-orphans
	printf "\nremit is purged. %s/.env and the compose files are untouched;\n" "$REMIT_DIR"
	printf "'remit restart' brings up an empty stack.\n"
}

# The root CA only exists in internal mode, and only on the caddy volume: the
# first thing an internal-mode operator has to do is get it off the box, so it
# is a command rather than a compose invocation to copy out of the docs.
cmd_cert() {
	require_deployment
	[ $# -eq 0 ] || die "cert: unknown option '$1'"
	_mode=$(get_var TLS_MODE)
	if [ "$_mode" != "internal" ]; then
		die "TLS_MODE is '$_mode', which has no root CA to export.
Only TLS_MODE=internal signs with Caddy's own CA. Under 'acme' and 'tailscale'
the certificate is already publicly trusted, and 'off' serves plain HTTP."
	fi
	_dest="$PWD/reader-root.crt"
	compose cp caddy:/data/caddy/pki/authorities/local/root.crt "$_dest" ||
		die "could not read the root CA from the caddy container.
Caddy generates it on its first start in internal mode — check 'remit status'
shows caddy running, then try again."
	printf 'Root CA written to %s\n\n' "$_dest"
	printf 'Import it into the trust store of every machine you browse from:\n'
	printf '  macOS    Keychain Access, then mark it "Always Trust"\n'
	printf '  Windows  certlm.msc, Trusted Root Certification Authorities\n'
	printf '  Linux    /usr/local/share/ca-certificates + update-ca-certificates\n'
	printf '  Firefox  Settings, Certificates, View Certificates, Authorities\n'
}

# Redaction keys off what a name says the value is, not off a list of known
# secrets: a list prints whatever secret is added to the template next in the
# clear, and MSOAUTH_CLIENT_SECRET and the RCLONE_* backup keys are already in
# there. compose honours `export K=` and indented keys alike, so the name is
# matched after stripping either.
cmd_config() {
	require_deployment
	awk '
		/^[ \t]*#/ { next }
		/^[ \t]*$/ { next }
		{
			line = $0
			sub(/^[ \t]+/, "", line)
			sub(/^export[ \t]+/, "", line)
			eq = index(line, "=")
			if (eq == 0) next
			k = substr(line, 1, eq - 1)
			v = substr(line, eq + 1)
			if (v == "") { print k "="; next }
			if (k ~ /SECRET|PASSWORD|TOKEN|DATAKEY|ACCESS_KEY|PRIVATE_KEY|CREDENTIAL/) {
				v = "<redacted>"
			} else if (v ~ /:\/\/[^\/@]*@/) {
				# Greedy to the last @: a password may contain one, and
				# stopping at the first prints its tail in the clear.
				sub(/:\/\/.*@/, "://<redacted>@", v)
			}
			print k "=" v
		}
	' "$REMIT_DIR/.env"
}

main() {
	[ $# -gt 0 ] || {
		usage >&2
		exit 2
	}
	_cmd=$1
	shift
	case "$_cmd" in
	restart) cmd_restart "$@" ;;
	logs) cmd_logs "$@" ;;
	status) cmd_status "$@" ;;
	update) cmd_update "$@" ;;
	down) cmd_down "$@" ;;
	purge) cmd_purge "$@" ;;
	config) cmd_config "$@" ;;
	cert) cmd_cert "$@" ;;
	help | --help | -h) usage ;;
	*)
		printf '%s: unknown command '\''%s'\''\n\n' "$PROG" "$_cmd" >&2
		usage >&2
		exit 2
		;;
	esac
}

main "$@"
