#!/bin/sh
#
# remit — admin wrapper for the self-host docker compose deployment.
#
# Wraps `docker compose` against the deployment directory so the operator
# never has to cd there or repeat -f/--env-file. install.sh rewrites both
# DEFAULT_DIR and COMPOSE_FILE below to what it installed; $REMIT_DIR selects
# a different directory.
#
# $REMIT_DIR chooses whose files and .env are used, not whose data is touched.
# The compose file pins `name: remit`, so every deployment on a host is the
# same Compose project, sharing container names and volumes.

set -eu

DEFAULT_DIR=/opt/remit
COMPOSE_FILE=docker-compose.sqlite.yml
REMIT_DIR="${REMIT_DIR:-$DEFAULT_DIR}"

PROG=remit

# --- self-update configuration (RFC 037) ------------------------------------
#
# STATE_DIR is where a run's lock, breadcrumb, state and snapshots live: the
# updater's own volume when this wrapper runs inside the updater container, a
# directory beside .env when an operator runs it from a shell. Never remit.db —
# a rollback restores that file to before the run, which would destroy the
# record of the rollback describing it.
#
# STATE_MOUNT is the same location named the way the *host* docker daemon reads
# it, because the helper containers below bind it. They are the same string
# outside a container; inside the updater they are not, so #133's compose
# service sets STATE_MOUNT to the volume it mounted.
STATE_DIR="${REMIT_UPDATE_STATE_DIR:-$REMIT_DIR/.update}"
STATE_MOUNT="${REMIT_UPDATE_STATE_MOUNT:-$STATE_DIR}"

# The database lives on a named volume, so reading and writing it means a
# container either way. alpine is what the backup sidecar already uses, and the
# restore path deliberately needs nothing installed into it — a rollback must
# not depend on the network that just failed.
HELPER_IMAGE="${REMIT_UPDATE_HELPER_IMAGE:-alpine:3.23}"
SQLITE_VOLUME="${REMIT_UPDATE_SQLITE_VOLUME:-remit_sqlite_data}"

# 300 seconds from `up -d` returning. Generous on purpose: a release that
# migrates a large mailbox index is the normal slow case, and rolling back a
# healthy-but-slow upgrade is worse than waiting.
GATE_BUDGET_SECONDS="${REMIT_UPDATE_GATE_BUDGET:-300}"

# Condition 4 is three consecutive answers 5 seconds apart, which is also the
# rhythm every other condition is re-read on.
GATE_PROBE_INTERVAL="${REMIT_UPDATE_PROBE_INTERVAL:-5}"

# Nothing is served and no worker runs between the snapshot and the verdict, so
# nothing is written, sent, purged or indexed in the window. volume-init joins
# by depends_on whether or not it is named.
GATE_SET="queue migrate backend"

# Scoped for gate conditions 2 and 3: migrate and volume-init are one-shots that
# exit by design, and caddy and backup are stock upstream images a tag change
# does not touch.
GATE_SERVICES="queue backend"

die() {
	printf '%s: %s\n' "$PROG" "$1" >&2
	exit 1
}

usage() {
	cat <<EOF
Usage: remit <command> [args]

  restart [--hard]     Start serving, applying any .env change. --hard stops
                       the stack first.
  logs [service...]    Follow logs (last 100 lines).
  status               Services and the running tag, plus whether the origin
                       resolves to this box and answers, the last update check
                       and the last update's outcome.
  update [--tag TAG]   Install a release. Against a running stack this is
                       atomic: the databases are snapshotted while the old
                       version is still live, the new one has to pass a health
                       gate before anything is served, and a failure restores
                       the snapshot and the previous tag.
  update --check       Check for a newer release and report, changing nothing.
  update --recover     Finish an update that was interrupted, committing or
                       rolling back on the gate's verdict. Runs at the
                       updater's start; safe to run by hand.
  down                 Stop serving: the site goes offline until 'remit
                       restart'. Accounts, mail and settings are untouched.
  purge --yes          Destroy the deployment: containers and every data
                       volume, accounts included. Without --yes it only says
                       what would go. Use 'down' to merely stop serving.
  config               Print the effective configuration, secrets redacted.
  cert                 Export Caddy's root CA to the current directory, so
                       browsers stop warning (TLS_MODE=internal only).
  probe-host <origin>  Report how a name resolves from this box. Used by
                       install.sh; useful on its own to check an origin.
  help                 This message.

Deployment directory: $REMIT_DIR (override with \$REMIT_DIR)
Compose file:         $REMIT_DIR/$COMPOSE_FILE
EOF
}

compose() {
	docker compose \
		--project-directory "$REMIT_DIR" \
		-f "$REMIT_DIR/$COMPOSE_FILE" \
		--env-file "$REMIT_DIR/.env" \
		"$@"
}

require_deployment() {
	[ -f "$REMIT_DIR/$COMPOSE_FILE" ] ||
		die "no $COMPOSE_FILE in $REMIT_DIR — point \$REMIT_DIR at the install directory, or run install.sh"
	[ -f "$REMIT_DIR/.env" ] ||
		die "no .env in $REMIT_DIR — point \$REMIT_DIR at the install directory, or run install.sh"
}

get_var() {
	_k=$1
	_k="$_k" awk '
		BEGIN { k = ENVIRON["_k"] }
		index($0, k "=") == 1 { print substr($0, length(k) + 2); exit }
	' "$REMIT_DIR/.env"
}

# The temp file holds FAKE_KMS_DATAKEY like the .env it replaces, so it is
# created under a 077 umask rather than chmod'd after the write: a chmod after
# the fact leaves the secrets world-readable for the length of the write.
set_var() {
	_k=$1
	_v=$2
	rm -f "$REMIT_DIR/.env.tmp"
	(
		umask 077
		_k="$_k" _v="$_v" awk '
			BEGIN { k = ENVIRON["_k"]; v = ENVIRON["_v"]; done = 0 }
			!done && index($0, k "=") == 1 { print k "=" v; done = 1; next }
			{ print }
			END { if (!done) print k "=" v }
		' "$REMIT_DIR/.env" >"$REMIT_DIR/.env.tmp"
	)
	mv "$REMIT_DIR/.env.tmp" "$REMIT_DIR/.env"
}

# Shared by `update` and by install.sh, which calls this wrapper rather than
# repeating the pull/up/migrate-gate sequence.
#
# The pull moves ~4 GB on a first install (search-index-worker alone is
# ~1.36 GB), so its progress is streamed rather than buffered for a diagnosis
# that is usually never needed — buffering makes a working install look hung
# for minutes. The copy kept on the side is only there to classify a failure,
# and the pull's own exit status has to be carried out of the pipeline by hand
# because the pipeline reports tee's.
pull_images() {
	_log=$(mktemp) || die "cannot create a temporary file for the pull log"
	_status=$(mktemp) || die "cannot create a temporary file for the pull status"
	# `|| _rc=$?` is what keeps set -e from killing the subshell before the
	# status is recorded; the status has to travel by file because the subshell
	# cannot assign to this one.
	{
		_rc=0
		compose pull 2>&1 || _rc=$?
		printf '%s' "$_rc" >"$_status"
	} | tee "$_log"
	_code=$(cat "$_status" 2>/dev/null || printf 1)
	rm -f "$_status"
	if [ "$_code" = "0" ]; then
		rm -f "$_log"
		return 0
	fi
	if grep -qiE 'denied|unauthorized|401|403' "$_log"; then
		rm -f "$_log"
		die "a registry refused the pull (see above).

This is not a missing token. Every image here pulls anonymously — the
ghcr.io/remit-mail/reader/* packages are public — so a refusal means a
credential was sent and rejected: an expired or revoked token left in
~/.docker/config.json by an earlier 'docker login' is offered instead of
pulling anonymously. Drop it and retry:

  docker logout ghcr.io       # or whichever registry the error names above
  remit update

Credentials are per-user, so a login done under sudo lives in root's config,
not yours. If neither is it, check whether the docker daemon is pointed at a
registry mirror or proxy fronting the registry above."
	fi
	rm -f "$_log"
	die "docker compose pull failed (see above)"
}

# migrate is a one-shot that every app service gates on
# (service_completed_successfully). If it fails, `up -d` reports a dependency
# error and the real cause is only in migrate's own logs.
check_migrate() {
	_cid=$(compose ps -aq migrate 2>/dev/null || true)
	if [ -z "$_cid" ]; then
		die "the migrate one-shot never ran — the stack is not usable"
	fi
	_code=$(docker inspect -f '{{.State.ExitCode}}' "$_cid" 2>/dev/null || echo 1)
	if [ "$_code" != "0" ]; then
		printf '\n--- migrate logs ---\n' >&2
		compose logs --no-log-prefix migrate >&2 2>/dev/null || true
		printf -- '--- end migrate logs ---\n\n' >&2
		die "the database migration failed (exit $_code). No app service starts until it succeeds."
	fi
}

apply() {
	if ! compose up -d; then
		check_migrate
		die "docker compose up failed (see above)"
	fi
	check_migrate
}

cmd_restart() {
	require_deployment
	if [ "${1:-}" = "--hard" ]; then
		compose stop
	elif [ -n "${1:-}" ]; then
		die "restart: unknown option '$1'"
	fi
	# up -d, never `compose restart`: restart reuses existing containers and
	# ignores .env changes, so config edits appear to apply but do not.
	apply
	report_serving
	printf 'Configuration in %s/.env is live.\n' "$REMIT_DIR"
}

cmd_logs() {
	require_deployment
	compose logs -f --tail=100 "$@"
}

# What the operator wants after a command that leaves the stack serving is the
# address, so it leads. A deployment part-way through configuration may not have
# one yet; that is not a reason to fail the command that just succeeded.
#
# install.sh sets $REMIT_QUIET because it prints its own summary immediately
# after, and two "Open <origin>" lines a screen apart read as two deployments.
report_serving() {
	if [ "${REMIT_QUIET:-0}" = "1" ]; then
		return 0
	fi
	_origin=$(get_var PUBLIC_ORIGIN 2>/dev/null || true)
	[ -n "$_origin" ] || return 0
	printf 'Open %s\n' "$_origin"
}

# --- reachability -----------------------------------------------------------
#
# A stack can be perfectly healthy and still be unreachable, because the name in
# PUBLIC_ORIGIN is answered somewhere the operator does not control. From the
# box that failure is invisible: the name resolves, the stack serves, `ps` is
# all green, and the browser hangs. These probes exist to name that case.
#
# `status` is what an operator types when something is already wrong, so no
# probe may hang, none may fail the command, and a missing tool degrades to a
# printed reason. install.sh runs `remit probe-host` rather than carrying a
# second copy of any of this.

PROBE_TIMEOUT=3

# coreutils timeout is the only thing that caps a command that will not cap
# itself. dig (+time), host (-W) and curl (-m) do; `getent ahosts` has no such
# flag, which is why resolver_tool drops it to last resort when timeout is
# missing rather than letting it block on the resolver's full retry budget.
capped() {
	if command -v timeout >/dev/null 2>&1; then
		timeout "$PROBE_TIMEOUT" "$@" 2>/dev/null || true
		return 0
	fi
	"$@" 2>/dev/null || true
}

have() { command -v "$1" >/dev/null 2>&1; }

origin_host() {
	_h=${1#*://}
	_h=${_h%%/*}
	_h=${_h#*@}
	case "$_h" in
	"["*) # bracketed IPv6 literal
		_h=${_h#[}
		_h=${_h%%]*}
		;;
	*) _h=${_h%%:*} ;;
	esac
	printf '%s' "$_h"
}

resolver_tool() {
	if have timeout; then
		set -- getent dig host
	else
		set -- dig host getent
	fi
	for _t in "$@"; do
		if have "$_t"; then
			printf '%s' "$_t"
			return 0
		fi
	done
	return 1
}

# A name that does not resolve is an ordinary empty result, never a failure.
# grep exits 1 on no match, which under a shell with `set -o pipefail` — as
# install.sh has, and this script does not — would otherwise become the
# pipeline's status and abort the caller. The braces contain it in both.
resolve_host() {
	case "$(resolver_tool)" in
	getent) capped getent ahosts "$1" | awk '{print $1}' | sort -u | tr '\n' ' ' ;;
	dig)
		# Both families explicitly: bare `dig +short` asks for A only, and a
		# box reachable over IPv6 alone would read as pointing elsewhere.
		{
			capped dig +short +time=2 +tries=1 A "$1"
			capped dig +short +time=2 +tries=1 AAAA "$1"
		} | { grep -E '^[0-9a-fA-F.:]+$' || true; } | sort -u | tr '\n' ' '
		;;
	host) capped host -W 2 "$1" | awk '/has( IPv6)? address/ {print $NF}' | sort -u | tr '\n' ' ' ;;
	esac
}

# An origin may name an address directly. getent resolves a literal to itself;
# dig and host ask DNS about it and come back empty, which would read as a name
# that does not resolve. Answer it here instead of per-tool.
is_ip_literal() {
	case "$1" in
	*:*) return 0 ;;
	*[!0-9.]*) return 1 ;;
	*.*) return 0 ;;
	esac
	return 1
}

local_addresses() {
	if have ip; then
		capped ip -o addr show | awk '{print $4}' | cut -d/ -f1
		return 0
	fi
	if have ifconfig; then
		capped ifconfig | awk '/inet6? /{print $2}' | sed 's/^addr://'
		return 0
	fi
	return 1
}

# The one classification both callers need, as one line: a verdict and the
# addresses behind it. install.sh formats its own pre-install wording from
# this; cmd_status formats the diagnostic wording below.
#
#   unresolved              the name answers with nothing
#   unknown                 no resolver, or this box's own addresses are unreadable
#   loopback <addrs>        resolves here and only here
#   held <addrs>            resolves to an address this box holds
#   elsewhere <addrs>       resolves to an address it does not
probe_host() {
	_host=$(origin_host "$1")
	if [ -z "$_host" ]; then
		printf 'unknown\n'
		return 0
	fi
	if is_ip_literal "$_host"; then
		_addrs=$_host
	else
		if ! resolver_tool >/dev/null; then
			printf 'unknown\n'
			return 0
		fi
		_addrs=$(resolve_host "$_host")
		_addrs=${_addrs% }
		if [ -z "$_addrs" ]; then
			printf 'unresolved\n'
			return 0
		fi
	fi

	_loopback_only=1
	for _a in $_addrs; do
		case "$_a" in
		127.* | ::1) ;;
		*) _loopback_only=0 ;;
		esac
	done
	if [ "$_loopback_only" = "1" ]; then
		printf 'loopback %s\n' "$_addrs"
		return 0
	fi

	_local=$(local_addresses || true)
	if [ -z "$_local" ]; then
		printf 'unknown %s\n' "$_addrs"
		return 0
	fi
	for _a in $_addrs; do
		for _l in $_local; do
			if [ "$_a" = "$_l" ]; then
				printf 'held %s\n' "$_addrs"
				return 0
			fi
		done
	done
	printf 'elsewhere %s\n' "$_addrs"
}

serve_probe() {
	if have curl; then
		# -k: internal mode is self-signed on purpose. An untrusted certificate
		# is the documented state there, not a reachability failure.
		_code=$(capped curl -k -s -o /dev/null -m "$PROBE_TIMEOUT" -w '%{http_code}' "$1")
		case "$_code" in
		"" | 000) printf 'no answer within %ss\n' "$PROBE_TIMEOUT" ;;
		*) printf 'HTTP %s\n' "$_code" ;;
		esac
		return 0
	fi
	if have wget; then
		if capped wget -q -O /dev/null --no-check-certificate -T "$PROBE_TIMEOUT" -t 1 "$1"; then
			printf 'answers\n'
		else
			printf 'no answer within %ss\n' "$PROBE_TIMEOUT"
		fi
		return 0
	fi
	printf 'not checked (no curl or wget)\n'
}

report_reachability() {
	_origin=$1
	[ -n "$_origin" ] || return 0
	_probe=$(probe_host "$_origin")
	_verdict=${_probe%% *}
	_addrs=${_probe#* }

	case "$_verdict" in
	unresolved)
		# Nothing to serve to, so there is nothing to probe either.
		printf 'Address:   %s does not resolve from this box — nothing loads there.\n' "$(origin_host "$_origin")"
		return 0
		;;
	elsewhere)
		printf 'Address:   %s\n' "$_addrs"
		printf '           This box does not hold that, so clients reach a different\n'
		printf '           machine, not this one.\n'
		# The probe follows the same name a browser does, so a healthy answer
		# came from that other machine. Saying so stops it reading as proof
		# this deployment is fine.
		printf 'Serving:   %s, at that address rather than here\n' "$(serve_probe "$_origin")"
		return 0
		;;
	loopback) printf 'Address:   %s — loopback, so reachable from this box only.\n' "$_addrs" ;;
	held) printf 'Address:   %s\n' "$_addrs" ;;
	*)
		if [ "$_addrs" = "$_verdict" ]; then
			printf 'Address:   not checked (no getent, dig or host on this box)\n'
		else
			printf 'Address:   %s\n' "$_addrs"
		fi
		;;
	esac
	printf 'Serving:   %s\n' "$(serve_probe "$_origin")"
}

cmd_status() {
	require_deployment
	_origin=$(get_var PUBLIC_ORIGIN)
	printf 'Directory: %s\n' "$REMIT_DIR"
	printf 'Tag:       %s\n' "$(get_var REMIT_TAG)"
	printf 'Origin:    %s\n' "$_origin"
	report_reachability "$_origin"
	report_check
	report_last_run
	printf '\n'
	compose ps
}

# --- self-update ------------------------------------------------------------
#
# RFC 037 D5, D6, D6a, D6b. `remit update` against a running stack is atomic:
# it snapshots the live databases before it stops anything, brings up a gate set
# that serves nobody, and either commits or restores the snapshot and the
# previous tag. There is one implementation of that sequence and this is it —
# the updater container (#133) runs this same wrapper, so an operator at a shell
# gets the same gate and the same rollback the app promises.
#
# Everything a run needs to survive its own death lives on the updater's volume:
# the lock, the breadcrumb, state.json and the snapshots. None of it goes in
# remit.db, because a rollback restores that file to before the run and would
# destroy the record of the rollback describing it.

RUN_ID=""
RUN_FROM=""
RUN_TARGET=""
RUN_STARTED=""
RUN_PHASE=""
RUN_SERVICES=""
RUN_MIGRATE_BEFORE=""
GATE_REASON=""
CHECK_VERSION=""
CHECK_AVAILABLE=""

epoch() { date -u +%s; }
iso_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }

# The manifest URL is deployment configuration, so .env is where it lives; the
# environment overrides it for a one-off check against a different origin.
manifest_url() {
	if [ -n "${REMIT_UPDATE_MANIFEST_URL:-}" ]; then
		printf '%s' "$REMIT_UPDATE_MANIFEST_URL"
		return 0
	fi
	get_var REMIT_UPDATE_MANIFEST_URL 2>/dev/null || true
}

# Fixed-shape JSON built with printf is the whole strategy: there is no jq on a
# self-host box and every shape here is ours. Only the free-text fields need
# care, and only for quotes, backslashes and newlines.
json_escape() {
	printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' | tr '\n\r\t' '   '
}

# Reads one string field out of flat JSON. The manifest and the request file are
# both flat and both ours to define, which is what makes this enough.
json_string() {
	printf '%s' "$1" | tr '\n' ' ' |
		sed -n 's/.*"'"$2"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
}

# BRE alternation is a GNU extension, so this reads the two literals instead.
json_bool() {
	case "$(printf '%s' "$1" | tr '\n' ' ')" in
	*"\"$2\":true"* | *"\"$2\": true"*) printf 'true' ;;
	*) printf 'false' ;;
	esac
}

new_run_id() {
	_rand=$(od -An -N4 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')
	if [ -z "$_rand" ]; then _rand=$$; fi
	printf '%s-%s' "$(date -u +%Y%m%dT%H%M%SZ)" "$_rand"
}

# Write-temp-then-rename is atomic but not durable, and the breadcrumb is the
# whole recovery guarantee — a host that loses power after the stop has to find
# it. The parent directory needs the same treatment: the rename is what has to
# survive, not just the bytes.
fsync_path() {
	sync "$1" 2>/dev/null || sync
}

atomic_write() {
	rm -f "$1.tmp"
	(
		umask 077
		cat >"$1.tmp"
	)
	mv "$1.tmp" "$1"
}

# --- breadcrumb -------------------------------------------------------------

breadcrumb_write() {
	mkdir -p "$STATE_DIR"
	{
		printf 'runId=%s\n' "$RUN_ID"
		printf 'fromVersion=%s\n' "$RUN_FROM"
		printf 'targetVersion=%s\n' "$RUN_TARGET"
		printf 'startedAt=%s\n' "$RUN_STARTED"
		printf 'snapshot=%s\n' "$STATE_DIR/snapshots/$RUN_ID"
		printf 'services=%s\n' "$RUN_SERVICES"
		printf 'migrateBefore=%s\n' "$RUN_MIGRATE_BEFORE"
		printf 'phase=%s\n' "$RUN_PHASE"
	} | atomic_write "$STATE_DIR/breadcrumb"
	fsync_path "$STATE_DIR/breadcrumb"
	fsync_path "$STATE_DIR"
}

breadcrumb_get() {
	[ -f "$STATE_DIR/breadcrumb" ] || return 1
	_k=$1
	_k="$_k" awk '
		BEGIN { k = ENVIRON["_k"] }
		index($0, k "=") == 1 { print substr($0, length(k) + 2); exit }
	' "$STATE_DIR/breadcrumb"
}

breadcrumb_clear() {
	rm -f "$STATE_DIR/breadcrumb"
	fsync_path "$STATE_DIR"
}

# --- state.json -------------------------------------------------------------
#
# The check block and the run block are independent by construction — they are
# separate files composed into one document — so a failed check renders as a
# failed check and never as a failed update.
#
# phase is one of checking, pulling, snapshotting, stopping, starting,
# verifying, committing, rollingBack, recovering. outcome is null while a run is
# in flight, then succeeded, rolledBack, rollbackFailed, or abandoned — the last
# for a run that ended having changed nothing, which is what an interrupted or
# aborted run before the stop terminates as.

state_render() {
	mkdir -p "$STATE_DIR"
	_check='{"status":"disabled"}'
	if [ -f "$STATE_DIR/check.json" ]; then
		_check=$(cat "$STATE_DIR/check.json")
	fi
	_run=null
	if [ -f "$STATE_DIR/run.json" ]; then
		_run=$(cat "$STATE_DIR/run.json")
	fi
	printf '{"currentVersion":"%s","check":%s,"run":%s}\n' \
		"$(json_escape "$(get_var REMIT_TAG)")" "$_check" "$_run" |
		atomic_write "$STATE_DIR/state.json"
}

# message and logCommand are rendered to the operator verbatim, so they are
# written as a sentence and as a command that can be pasted into a shell — not
# as debug output.
run_state_write() {
	_phase=$1
	_outcome=$2
	_message=$3
	_logcmd=$4
	mkdir -p "$STATE_DIR"
	_outjson=null
	if [ -n "$_outcome" ]; then
		_outjson=$(printf '"%s"' "$(json_escape "$_outcome")")
	fi
	printf '{"runId":"%s","fromVersion":"%s","targetVersion":"%s","phase":"%s","outcome":%s,"startedAt":"%s","updatedAt":"%s","message":"%s","logCommand":"%s"}\n' \
		"$(json_escape "$RUN_ID")" \
		"$(json_escape "$RUN_FROM")" \
		"$(json_escape "$RUN_TARGET")" \
		"$(json_escape "$_phase")" \
		"$_outjson" \
		"$(json_escape "$RUN_STARTED")" \
		"$(json_escape "$(iso_now)")" \
		"$(json_escape "$_message")" \
		"$(json_escape "$_logcmd")" |
		atomic_write "$STATE_DIR/run.json"
	state_render
}

phase() {
	RUN_PHASE=$1
	run_state_write "$1" "" "$2" "$3"
	breadcrumb_write
	if [ "${REMIT_QUIET:-0}" != "1" ]; then
		printf '%s\n' "$2"
	fi
}

terminate() {
	run_state_write "$RUN_PHASE" "$1" "$2" "$3"
	breadcrumb_clear
	if [ "${REMIT_QUIET:-0}" != "1" ]; then
		printf '%s\n' "$2"
	fi
}

# --- lock -------------------------------------------------------------------
#
# flock, not a lockfile. A plain lockfile left behind by an updater killed at
# the stop is still there when it restarts, so boot recovery would refuse to run
# and leave an offline box needing a shell — reached through the mechanism built
# to prevent exactly that. The kernel releases a flock when its holder dies, and
# two racing recovery attempts then resolve for free.
lock_acquire() {
	mkdir -p "$STATE_DIR"
	have flock || die "flock is not on this box, and an update must not run without a lock.
Install util-linux (or busybox's flock) and try again."
	exec 9>"$STATE_DIR/update.lock"
	flock -n 9 ||
		die "another update is already running on this box. Wait for it to finish, or see 'remit status'."
}

# --- manifest check (RFC 037 R4, R5) ----------------------------------------
#
# The manifest is the entire discovery mechanism. There is no registry tag
# listing, no "does this tag exist" probe and no fallback that reads the
# registry when the manifest is unreachable — image pushes are not atomic across
# the roster, so a tag can be present and pullable for a version that was never
# fully published and never can be. An unreachable manifest is a failed check
# and no update offered; it is never a reason to look somewhere else.

fetch_manifest() {
	if have curl; then
		curl -fsSL --max-time 20 --max-filesize 65536 "$1" 2>/dev/null
		return
	fi
	if have wget; then
		wget -q -T 20 -O - "$1" 2>/dev/null | head -c 65536
		return
	fi
	return 127
}

version_valid() {
	printf '%s' "$1" | grep -qE '^v[0-9]+\.[0-9]+\.[0-9]+$'
}

# An operator may pin a sha-<sha> build or `latest`; those are tags, not
# versions, and they are still allowed as an explicit --tag target. Anything
# outside this set never reaches a docker command line.
tag_valid() {
	printf '%s' "$1" | grep -qE '^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$'
}

version_gt() {
	_a=${1#v}
	_b=${2#v}
	_i=1
	while [ "$_i" -le 3 ]; do
		_x=$(printf '%s' "$_a" | cut -d. -f"$_i")
		_y=$(printf '%s' "$_b" | cut -d. -f"$_i")
		if [ "$_x" -gt "$_y" ]; then return 0; fi
		if [ "$_x" -lt "$_y" ]; then return 1; fi
		_i=$((_i + 1))
	done
	return 1
}

# The tag-parameterised images — the ones a release actually moves. caddy and
# alpine are stock upstream images that a manifest has no say over.
release_images() {
	# shellcheck disable=SC2016 # ${REMIT_TAG} is compose's syntax, matched literally
	sed -n 's/^[[:space:]]*image:[[:space:]]*\(.*\)$/\1/p' "$REMIT_DIR/$COMPOSE_FILE" |
		grep '\${REMIT_TAG' |
		sed 's/:\${REMIT_TAG.*$//' |
		sort -u
}

images_under_registry() {
	_outside=$(release_images | grep -v "^$1/" || true)
	[ -z "$_outside" ]
}

check_failed() {
	printf '{"status":"failed","lastCheckedAt":"%s","error":"%s"}\n' \
		"$(iso_now)" "$(json_escape "$1")" | atomic_write "$STATE_DIR/check.json"
	state_render
	CHECK_VERSION=""
	CHECK_AVAILABLE=false
}

# Sets CHECK_VERSION and CHECK_AVAILABLE, and writes the check block. Returns
# non-zero only when the check itself failed — "no update available" is a
# successful check.
do_check() {
	mkdir -p "$STATE_DIR"
	CHECK_VERSION=""
	CHECK_AVAILABLE=false
	_url=$(manifest_url)
	if [ -z "$_url" ]; then
		printf '{"status":"disabled"}\n' | atomic_write "$STATE_DIR/check.json"
		state_render
		return 0
	fi
	_body=$(fetch_manifest "$_url" || true)
	if [ -z "$_body" ]; then
		check_failed "The update manifest at $_url could not be fetched."
		return 1
	fi
	_ver=$(json_string "$_body" version)
	_reg=$(json_string "$_body" registry)
	if ! version_valid "$_ver"; then
		check_failed "The update manifest at $_url does not name a vX.Y.Z version."
		return 1
	fi
	if [ -z "$_reg" ]; then
		check_failed "The update manifest at $_url does not name a registry."
		return 1
	fi
	if ! images_under_registry "$_reg"; then
		check_failed "This deployment runs images from outside $_reg, which the manifest does not cover."
		return 1
	fi
	_cur=$(get_var REMIT_TAG)
	# A tag that is not a version — `latest`, or a pinned sha- build — cannot be
	# compared, so the published release is offered rather than hidden.
	if ! version_valid "$_cur"; then
		CHECK_AVAILABLE=true
	elif version_gt "$_ver" "$_cur"; then
		CHECK_AVAILABLE=true
	fi
	CHECK_VERSION=$_ver
	write_check_ok "$(iso_now)" "$_ver" \
		"$(json_string "$_body" publishedAt)" \
		"$(json_string "$_body" summary)" \
		"$(json_string "$_body" releaseNotesUrl)" \
		"$CHECK_AVAILABLE"
	return 0
}

write_check_ok() {
	printf '{"status":"ok","lastCheckedAt":"%s","latestVersion":"%s","publishedAt":"%s","summary":"%s","releaseNotesUrl":"%s","updateAvailable":%s}\n' \
		"$(json_escape "$1")" \
		"$(json_escape "$2")" \
		"$(json_escape "$3")" \
		"$(json_escape "$4")" \
		"$(json_escape "$5")" \
		"$6" | atomic_write "$STATE_DIR/check.json"
	state_render
}

# updateAvailable is a statement about the version that is running, so a run
# that changed which version that is has to restate it. Nothing is fetched: the
# manifest said what the latest release is and that has not changed.
recheck_availability() {
	[ -f "$STATE_DIR/check.json" ] || return 0
	_c=$(cat "$STATE_DIR/check.json")
	[ "$(json_string "$_c" status)" = "ok" ] || return 0
	_latest=$(json_string "$_c" latestVersion)
	_cur=$(get_var REMIT_TAG)
	_avail=false
	if ! version_valid "$_cur"; then
		_avail=true
	elif version_gt "$_latest" "$_cur"; then
		_avail=true
	fi
	write_check_ok \
		"$(json_string "$_c" lastCheckedAt)" \
		"$_latest" \
		"$(json_string "$_c" publishedAt)" \
		"$(json_string "$_c" summary)" \
		"$(json_string "$_c" releaseNotesUrl)" \
		"$_avail"
}

# The control seam (#133): request.json is written wholly by the backend, so
# under a compromised backend its entire content is attacker-controlled — not
# only the field it is supposed to carry. The file is read bounded, exactly one
# key is looked at, and the value has to match vX.Y.Z *and* the manifest's own
# version before it is used anywhere. Every other key is ignored rather than
# trusted.
requested_target() {
	[ -f "$STATE_DIR/request.json" ] || return 1
	_raw=$(head -c 4096 "$STATE_DIR/request.json")
	_want=$(json_string "$_raw" targetVersion)
	if ! version_valid "$_want"; then
		return 1
	fi
	if [ "$_want" != "$CHECK_VERSION" ]; then
		return 1
	fi
	printf '%s' "$_want"
}

# --- snapshot and restore (RFC 037 R8, R8a) ---------------------------------
#
# The databases live on a named volume, so both directions run in a container
# that mounts it. queue.db is on a different volume and is not mounted here at
# all: restoring a work queue resurrects already-delivered outbound mail, which
# is a correctness bug rather than a cost. Nothing in the gate window writes it,
# so leaving it alone is right in both directions.

volume_run() {
	docker run --rm \
		-v "$SQLITE_VOLUME:/data/sqlite" \
		-v "$STATE_MOUNT:/state" \
		-v "$REMIT_DIR/backup/snapshot-db.sh:/snapshot-db.sh:ro" \
		--entrypoint sh "$HELPER_IMAGE" -c "$1"
}

# VACUUM INTO against the live databases, before anything is stopped. sqlite3 is
# apk'd the way the backup sidecar already does; the snapshot runs as uid 1000
# because opening a WAL database recreates its -shm/-wal sidecars when they are
# absent, and a root-owned sidecar makes every app writer's next open fail.
snapshot_databases() {
	volume_run "set -eu
apk add --no-cache sqlite su-exec >/dev/null
mkdir -p /state/snapshots/$1
chown 1000:1000 /state/snapshots/$1
exec su-exec 1000:1000 sh -c '. /snapshot-db.sh
snapshot_db /data/sqlite/remit.db /state/snapshots/$1/remit.db
snapshot_db /data/sqlite/vec.db /state/snapshots/$1/vec.db'"
}

# Installs nothing: a rollback must not depend on the network whose failure it
# may be recovering from. The unlinks are not tidiness — VACUUM INTO writes a
# fresh file with its own salt, so a WAL left behind by the stop is a mismatched
# sidecar beside a database that never wrote it. The chown is what keeps a
# successful rollback from terminating as rollbackFailed: the updater is root,
# every app container is uid 1000, and a root-owned file on that volume fails
# the gate re-run with EACCES.
restore_snapshot() {
	volume_run "set -eu
snap=/state/snapshots/$1
if [ ! -f \"\$snap/remit.db\" ]; then
  echo 'the snapshot for this run is missing' >&2
  exit 1
fi
rm -f /data/sqlite/remit.db /data/sqlite/remit.db-wal /data/sqlite/remit.db-shm
cp \"\$snap/remit.db\" /data/sqlite/remit.db
if [ -f \"\$snap/vec.db\" ]; then
  rm -f /data/sqlite/vec.db /data/sqlite/vec.db-wal /data/sqlite/vec.db-shm
  cp \"\$snap/vec.db\" /data/sqlite/vec.db
fi
chown -R 1000:1000 /data/sqlite"
}

prune_snapshots() {
	[ -d "$STATE_DIR/snapshots" ] || return 0
	for _d in "$STATE_DIR/snapshots"/*; do
		[ -d "$_d" ] || continue
		_name=${_d##*/}
		if [ "$_name" != "$1" ]; then
			rm -rf "$_d"
		fi
	done
}

# --- the gate (RFC 037 D5, R9) ----------------------------------------------
#
# All four conditions within the budget, against a stack that is serving nobody.
# A return of 2 from a condition is terminal — waiting cannot change it — and 1
# means not yet.

service_cid() {
	compose ps -aq "$1" 2>/dev/null | tail -1
}

gate_baseline() {
	: >"$STATE_DIR/gate-baseline"
	for _svc in $GATE_SERVICES; do
		_cid=$(service_cid "$_svc")
		_rc=0
		if [ -n "$_cid" ]; then
			_rc=$(docker inspect -f '{{.RestartCount}}' "$_cid" 2>/dev/null || printf 0)
		fi
		printf '%s %s\n' "$_svc" "$_rc" >>"$STATE_DIR/gate-baseline"
	done
}

baseline_of() {
	_v=$(awk -v s="$1" '$1 == s { print $2; exit }' "$STATE_DIR/gate-baseline" 2>/dev/null || true)
	if [ -z "$_v" ]; then _v=0; fi
	printf '%s' "$_v"
}

# Condition 1. The container id has to have changed across the recreate before
# the exit code counts: reading whatever `compose ps -aq migrate` finds is
# satisfied by the previous run's exited container, so a recreate that silently
# no-ops would read an old success and pass an update whose migration never ran.
gate_migrate() {
	_cid=$(service_cid migrate)
	if [ -z "$_cid" ]; then
		GATE_REASON="the database migration never ran"
		return 2
	fi
	if [ -n "$1" ] && [ "$_cid" = "$1" ]; then
		GATE_REASON="the database migration did not run — its container was never replaced"
		return 2
	fi
	_status=$(docker inspect -f '{{.State.Status}}' "$_cid" 2>/dev/null || printf unknown)
	if [ "$_status" != "exited" ]; then
		GATE_REASON="the database migration has not finished"
		return 1
	fi
	_code=$(docker inspect -f '{{.State.ExitCode}}' "$_cid" 2>/dev/null || printf 1)
	if [ "$_code" != "0" ]; then
		GATE_REASON="the database migration failed (exit $_code)"
		return 2
	fi
	return 0
}

# Condition 2. A restart count that moved means the service exited and came back
# — a crash loop, which waiting cannot fix.
gate_running() {
	for _svc in $GATE_SERVICES; do
		_cid=$(service_cid "$_svc")
		if [ -z "$_cid" ]; then
			GATE_REASON="$_svc is not running"
			return 1
		fi
		_running=$(docker inspect -f '{{.State.Running}}' "$_cid" 2>/dev/null || printf false)
		if [ "$_running" != "true" ]; then
			GATE_REASON="$_svc is not running"
			return 1
		fi
		_rc=$(docker inspect -f '{{.RestartCount}}' "$_cid" 2>/dev/null || printf 0)
		if [ "$_rc" -gt "$(baseline_of "$_svc")" ]; then
			GATE_REASON="$_svc keeps restarting"
			return 2
		fi
	done
	return 0
}

# Condition 3. Services without a healthcheck report none and pass; the
# healthchecks that make this more than "the port answers" are on backend,
# apisix and web.
gate_healthy() {
	for _svc in $GATE_SERVICES; do
		_cid=$(service_cid "$_svc")
		if [ -z "$_cid" ]; then
			GATE_REASON="$_svc is not running"
			return 1
		fi
		_h=$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$_cid" 2>/dev/null || printf unknown)
		case "$_h" in
		none | healthy) ;;
		*)
			GATE_REASON="$_svc is not healthy ($_h)"
			return 1
			;;
		esac
	done
	return 0
}

# Condition 4. The backend directly: APISIX is held down for the whole window,
# so there is nothing else to ask. Joining the backend's own network namespace
# avoids having to know what the compose network is called, and fails by itself
# when the backend has no container.
probe_backend() {
	_cid=$(compose ps -q backend 2>/dev/null | tail -1)
	if [ -z "$_cid" ]; then
		return 1
	fi
	docker run --rm --network "container:$_cid" "$HELPER_IMAGE" \
		wget -q -T 5 -O /dev/null http://127.0.0.1:8080/health >/dev/null 2>&1
}

run_gate() {
	_migrate_before=$1
	GATE_REASON="the new version did not answer within ${GATE_BUDGET_SECONDS}s"
	_deadline=$(($(epoch) + GATE_BUDGET_SECONDS))
	_probes=0
	while :; do
		_rc=0
		gate_migrate "$_migrate_before" || _rc=$?
		if [ "$_rc" = "0" ]; then
			_rc=0
			gate_running || _rc=$?
		fi
		if [ "$_rc" = "0" ]; then
			_rc=0
			gate_healthy || _rc=$?
		fi
		if [ "$_rc" = "2" ]; then
			return 1
		fi
		if [ "$_rc" = "0" ]; then
			if probe_backend; then
				_probes=$((_probes + 1))
				if [ "$_probes" -ge 3 ]; then
					GATE_REASON=""
					return 0
				fi
			else
				_probes=0
				GATE_REASON="the new backend did not answer /health"
			fi
		else
			_probes=0
		fi
		if [ "$(epoch)" -ge "$_deadline" ]; then
			return 1
		fi
		sleep "$GATE_PROBE_INTERVAL"
	done
}

# --- the sequence -----------------------------------------------------------

stack_is_running() {
	_n=$(compose ps -q 2>/dev/null | wc -l)
	[ "$_n" -gt 0 ]
}

running_services() {
	compose ps --services --status running 2>/dev/null | grep -vx updater | tr '\n' ' '
}

# `backup` is the reason this is not a bare `compose stop`. It is a stock alpine
# image under `restart: unless-stopped` behind a profile, so a stop scoped to the
# active profiles leaves it running — and it opens remit.db read-write every
# interval for its own VACUUM INTO, which is harmless during the gate window and
# a collision during the restore. Anything still up after the stop is named and
# stopped again.
stop_everything() {
	compose stop
	_left=$(compose ps --services --status running 2>/dev/null | grep -vx updater | tr '\n' ' ')
	if [ -n "$_left" ]; then
		# shellcheck disable=SC2086 # a service list, split on purpose
		compose stop $_left
	fi
}

start_gate_set() {
	RUN_MIGRATE_BEFORE=$(service_cid migrate)
	breadcrumb_write
	# shellcheck disable=SC2086 # GATE_SET is a service list, split on purpose
	compose up -d $GATE_SET
	gate_baseline
}

start_held_back() {
	if [ -n "$RUN_SERVICES" ]; then
		# shellcheck disable=SC2086 # the recorded service list, split on purpose
		compose up -d $RUN_SERVICES
	fi
}

# `compose up -d updater` recreates the container this is running in, so it is
# the last thing that happens and the verdict is already durable before it does.
# Being killed here loses nothing.
replace_updater() {
	if compose config --services 2>/dev/null | grep -qx updater; then
		compose up -d updater || true
	fi
}

commit_run() {
	phase committing "Starting the rest of the services." "remit logs"
	start_held_back
	# This run's snapshot and the previous release's images are retained until
	# the next successful update; every earlier run's snapshot goes.
	prune_snapshots "$RUN_ID"
	recheck_availability
	terminate succeeded "This instance is now running $RUN_TARGET." "remit logs backend"
	replace_updater
}

roll_back() {
	_why=$1
	phase rollingBack "$_why. Restoring $RUN_FROM and the database as it was before the update." "remit logs backend"
	stop_everything
	if ! restore_snapshot "$RUN_ID"; then
		terminate rollbackFailed \
			"$_why, and the database snapshot could not be restored. The snapshot is at $STATE_DIR/snapshots/$RUN_ID and the previous version is $RUN_FROM." \
			"remit logs backend"
		return 1
	fi
	set_var REMIT_TAG "$RUN_FROM"
	REMIT_TAG=$RUN_FROM
	export REMIT_TAG
	recheck_availability
	start_gate_set
	if run_gate "$RUN_MIGRATE_BEFORE"; then
		start_held_back
		prune_snapshots "$RUN_ID"
		terminate rolledBack \
			"$_why. This instance was restored to $RUN_FROM and is serving again." \
			"remit logs backend"
		replace_updater
		return 0
	fi
	terminate rollbackFailed \
		"$_why, and $RUN_FROM did not come back either ($GATE_REASON). The snapshot taken before the update is at $STATE_DIR/snapshots/$RUN_ID." \
		"remit logs backend"
	return 1
}

run_update() {
	_target=$1
	RUN_ID=$(new_run_id)
	RUN_FROM=$(get_var REMIT_TAG)
	RUN_TARGET=$_target
	RUN_STARTED=$(iso_now)
	RUN_SERVICES=$(running_services)
	RUN_MIGRATE_BEFORE=""
	mkdir -p "$STATE_DIR"

	phase checking "Preparing to update from $RUN_FROM to $_target." "remit status"

	# Nothing running is touched by the pull, so a failure here — a registry
	# refusal, a rate limit, a full disk — aborts having changed nothing and a
	# retry is safe.
	phase pulling "Downloading $_target." "remit logs"
	REMIT_TAG=$_target
	export REMIT_TAG
	if ! (pull_images); then
		REMIT_TAG=$RUN_FROM
		export REMIT_TAG
		terminate abandoned \
			"$_target could not be downloaded, so nothing was changed and this instance is still running $RUN_FROM." \
			"remit update"
		rm -rf "$STATE_DIR/snapshots/$RUN_ID"
		return 1
	fi

	# Against the live databases, before anything is stopped. A copy taken after
	# the stop silently drops every transaction still in the write-ahead log,
	# and the restore looks clean.
	phase snapshotting "Taking a snapshot of the database." "remit status"
	if ! snapshot_databases "$RUN_ID"; then
		REMIT_TAG=$RUN_FROM
		export REMIT_TAG
		terminate abandoned \
			"The database could not be snapshotted, so nothing was changed and this instance is still running $RUN_FROM." \
			"remit status"
		rm -rf "$STATE_DIR/snapshots/$RUN_ID"
		return 1
	fi

	# Before the stop, never at commit. If the updater dies and the host
	# reboots, the restart policy has to bring up binaries that match the
	# migrated database.
	set_var REMIT_TAG "$_target"

	phase stopping "Stopping services." "remit status"
	stop_everything

	phase starting "Starting $_target." "remit logs backend"
	start_gate_set

	phase verifying "Waiting for $_target to answer." "remit logs backend"
	if run_gate "$RUN_MIGRATE_BEFORE"; then
		commit_run
		return 0
	fi
	roll_back "$GATE_REASON"
}

# --- recovery (RFC 037 D6a, R11) --------------------------------------------
#
# Run at the updater's start. A breadcrumb with no terminal outcome means the
# updater died mid-run, and the answer is neither to resume nor to sit still. It
# branches on the recorded phase first and only then consults the gate, because
# a bare gate re-run reaches two wrong verdicts: before the stop the old version
# is still up and healthy, so the gate passes and success is reported for a
# version that was never installed; and after a restore during a rollback the
# stack may be up on the new tag against the reverted database, so a passing
# /health commits an update that was deliberately undone.
recover_run() {
	if [ ! -f "$STATE_DIR/breadcrumb" ]; then
		printf 'No interrupted update to recover.\n'
		return 0
	fi
	RUN_ID=$(breadcrumb_get runId)
	RUN_FROM=$(breadcrumb_get fromVersion)
	RUN_TARGET=$(breadcrumb_get targetVersion)
	RUN_STARTED=$(breadcrumb_get startedAt)
	RUN_SERVICES=$(breadcrumb_get services)
	RUN_MIGRATE_BEFORE=$(breadcrumb_get migrateBefore)
	_was=$(breadcrumb_get phase)

	case "$_was" in
	checking | pulling | snapshotting)
		RUN_PHASE=recovering
		terminate abandoned \
			"The update to $RUN_TARGET was interrupted before anything was changed; this instance is still running $RUN_FROM." \
			"remit status"
		rm -rf "$STATE_DIR/snapshots/$RUN_ID"
		;;
	stopping | starting | verifying | committing)
		phase verifying "Checking whether $RUN_TARGET came up after an interrupted update." "remit logs backend"
		# A fresh `compose up` here is what re-reads .env: `unless-stopped` does
		# not restart containers that were explicitly stopped, so a host reboot
		# between the stop and the start leaves the app plane down until this.
		start_gate_set
		if run_gate "$RUN_MIGRATE_BEFORE"; then
			commit_run
			return 0
		fi
		roll_back "$GATE_REASON"
		;;
	rollingBack)
		# The only legal outcomes here are rolledBack and rollbackFailed,
		# whatever the gate says.
		roll_back "the update to $RUN_TARGET was interrupted while rolling back"
		;;
	*)
		RUN_PHASE=recovering
		terminate abandoned \
			"An interrupted update was found in an unknown state and abandoned; this instance is running $(get_var REMIT_TAG)." \
			"remit status"
		;;
	esac
}

# --- the command ------------------------------------------------------------

# The legacy path, and still the right one: on a box with nothing running there
# is no old version to snapshot, nothing to hold down and nothing to roll back
# to. install.sh's first `remit update` lands here.
plain_update() {
	_tag=$1
	# The tag reaches .env only once its images are on the box. Writing it
	# first leaves .env naming a version that failed to pull, which is then
	# what the next `up` — or the next operator reading it — believes is
	# running. Compose reads the exported value ahead of the .env one, so the
	# pull is already the new tag's.
	if [ -n "$_tag" ]; then
		REMIT_TAG=$_tag
		export REMIT_TAG
	fi
	pull_images
	if [ -n "$_tag" ]; then
		set_var REMIT_TAG "$_tag"
	fi
	apply
	if [ "${REMIT_QUIET:-0}" != "1" ]; then
		printf '\n'
		report_serving
		printf 'Running tag %s.\n' "$(get_var REMIT_TAG)"
	fi
}

cmd_update() {
	require_deployment
	_tag=""
	_mode=update
	while [ $# -gt 0 ]; do
		case "$1" in
		--tag)
			[ $# -ge 2 ] || die "update: --tag needs a value"
			_tag=$2
			tag_valid "$_tag" || die "update: '$_tag' is not a usable image tag"
			shift 2
			;;
		--check)
			_mode=check
			shift
			;;
		--recover)
			_mode=recover
			shift
			;;
		*) die "update: unknown option '$1'" ;;
		esac
	done

	if [ "$_mode" = "recover" ]; then
		lock_acquire
		recover_run
		return 0
	fi

	do_check || true

	if [ "$_mode" = "check" ]; then
		report_check
		return 0
	fi

	lock_acquire

	if [ -z "$_tag" ] && [ -f "$STATE_DIR/request.json" ]; then
		_tag=$(requested_target || true)
		# Consumed either way: a request that was refused must not be retried on
		# every later run, and one that was taken is now the run's business.
		rm -f "$STATE_DIR/request.json"
		if [ -z "$_tag" ]; then
			die "update: the update request on the control volume did not name the published version and was discarded"
		fi
	fi

	# A box with nothing running has no old version to snapshot, nothing to hold
	# down and nothing to roll back to, so it takes the plain path — this is
	# install.sh's first `remit update`, and it is also why a manifest version is
	# never adopted silently on a fresh install.
	if ! stack_is_running; then
		plain_update "$_tag"
		return 0
	fi

	if [ -z "$_tag" ] && [ "$CHECK_AVAILABLE" = "true" ]; then
		_tag=$CHECK_VERSION
	fi
	if [ -z "$_tag" ]; then
		if [ -n "$(manifest_url)" ]; then
			report_check
			return 0
		fi
		plain_update ""
		return 0
	fi

	run_update "$_tag"
}

report_check() {
	if [ ! -f "$STATE_DIR/check.json" ]; then
		printf 'Updates:   never checked — run '\''remit update --check'\''\n'
		return 0
	fi
	_c=$(cat "$STATE_DIR/check.json")
	case "$(json_string "$_c" status)" in
	disabled)
		printf 'Updates:   not configured (REMIT_UPDATE_MANIFEST_URL is unset)\n'
		;;
	failed)
		printf 'Updates:   check failed — %s\n' "$(json_string "$_c" error)"
		;;
	*)
		if [ "$(json_bool "$_c" updateAvailable)" = "true" ]; then
			printf 'Updates:   %s is available — %s\n' \
				"$(json_string "$_c" latestVersion)" "$(json_string "$_c" summary)"
			printf "           Install it with: remit update\n"
		else
			printf 'Updates:   up to date (%s, checked %s)\n' \
				"$(json_string "$_c" latestVersion)" "$(json_string "$_c" lastCheckedAt)"
		fi
		;;
	esac
}

# The last run, as a sentence. message and logCommand are the same strings the
# app renders, so a shell and a browser never tell the operator two stories.
report_last_run() {
	[ -f "$STATE_DIR/run.json" ] || return 0
	_r=$(cat "$STATE_DIR/run.json")
	_outcome=$(json_string "$_r" outcome)
	if [ -z "$_outcome" ]; then
		printf 'Update:    in progress (%s) — %s\n' \
			"$(json_string "$_r" phase)" "$(json_string "$_r" message)"
	else
		printf 'Update:    %s — %s\n' "$_outcome" "$(json_string "$_r" message)"
	fi
	printf '           %s\n' "$(json_string "$_r" logCommand)"
}

cmd_down() {
	require_deployment
	# stop, never `down`: the sqlite_data and message_storage volumes hold every
	# account, credential and message body on this box.
	compose stop
	_origin=$(get_var PUBLIC_ORIGIN 2>/dev/null || true)
	if [ -n "$_origin" ]; then
		printf "remit is stopped: %s serves nothing until 'remit restart'.\n" "$_origin"
	else
		printf "remit is stopped: nothing is served until 'remit restart'.\n"
	fi
	printf "No data was removed — accounts, mail and settings come back with it.\n"
}

# The one destructive command. --yes is the confirmation: the wrapper has to
# work under `curl | bash`-style non-interactive use, so it never reads stdin.
cmd_purge() {
	require_deployment
	_yes=0
	while [ $# -gt 0 ]; do
		case "$1" in
		--yes)
			_yes=1
			shift
			;;
		*) die "purge: unknown option '$1'" ;;
		esac
	done
	if [ "$_yes" != "1" ]; then
		cat >&2 <<EOF
purge would destroy this deployment's data. Nothing has been touched.

It removes every container and network, and these volumes:

  sqlite_data      every account, message index, tag and setting
  message_storage  the cached message bodies
  queue_data       work still queued
  caddy_data       the TLS certificates, including the internal root CA
  caddy_config     caddy's own state

Your accounts and everything you have organised in the app are gone with
sqlite_data and do not come back. Message bodies do: they are a cache of IMAP,
which is the source of truth, so they re-sync once an account is added again.

The install directory is left alone, .env and its FAKE_KMS_DATAKEY included:
  $REMIT_DIR
So 'remit restart' afterwards brings up an empty but working stack.

Those volumes belong to the host, not to that directory: every deployment on
this box is the same Compose project, so a second install directory shares
exactly these volumes and loses its data here too.

To stop serving without destroying anything, use 'remit down'.
Run 'remit purge --yes' if this is what you want.
EOF
		exit 1
	fi
	compose down -v --remove-orphans
	printf "\nremit is purged. %s/.env and the compose files are untouched;\n" "$REMIT_DIR"
	printf "'remit restart' brings up an empty stack.\n"
}

# The root CA only exists in internal mode, and only on the caddy volume: the
# first thing an internal-mode operator has to do is get it off the box, so it
# is a command rather than a compose invocation to copy out of the docs.
cmd_cert() {
	require_deployment
	[ $# -eq 0 ] || die "cert: unknown option '$1'"
	_mode=$(get_var TLS_MODE)
	if [ "$_mode" != "internal" ]; then
		die "TLS_MODE is '$_mode', which has no root CA to export.
Only TLS_MODE=internal signs with Caddy's own CA. Under 'acme' and 'tailscale'
the certificate is already publicly trusted, and 'off' serves plain HTTP."
	fi
	_dest="$PWD/reader-root.crt"
	# Checked separately, because `compose cp` reports an unwritable destination
	# and an absent container the same way, and the message below names only one.
	[ -w "$PWD" ] ||
		die "cannot write to $PWD — run 'remit cert' from a directory you own."
	compose cp caddy:/data/caddy/pki/authorities/local/root.crt "$_dest" ||
		die "could not read the root CA from the caddy container.
Caddy generates it on its first start in internal mode — check 'remit status'
shows caddy running, then try again."
	printf 'Root CA written to %s\n\n' "$_dest"
	printf 'Import it into the trust store of every machine you browse from:\n'
	printf '  macOS    Keychain Access, then mark it "Always Trust"\n'
	printf '  Windows  certlm.msc, Trusted Root Certification Authorities\n'
	printf '  Linux    /usr/local/share/ca-certificates + update-ca-certificates\n'
	printf '  Firefox  Settings, Certificates, View Certificates, Authorities\n'
}

# Redaction keys off what a name says the value is, not off a list of known
# secrets: a list prints whatever secret is added to the template next in the
# clear, and MSOAUTH_CLIENT_SECRET and the RCLONE_* backup keys are already in
# there. compose honours `export K=` and indented keys alike, so the name is
# matched after stripping either.
cmd_config() {
	require_deployment
	awk '
		/^[ \t]*#/ { next }
		/^[ \t]*$/ { next }
		{
			line = $0
			sub(/^[ \t]+/, "", line)
			sub(/^export[ \t]+/, "", line)
			eq = index(line, "=")
			if (eq == 0) next
			k = substr(line, 1, eq - 1)
			v = substr(line, eq + 1)
			if (v == "") { print k "="; next }
			if (k ~ /SECRET|PASSWORD|TOKEN|DATAKEY|ACCESS_KEY|PRIVATE_KEY|CREDENTIAL/) {
				v = "<redacted>"
			} else if (v ~ /:\/\/[^\/@]*@/) {
				# Greedy to the last @: a password may contain one, and
				# stopping at the first prints its tail in the clear.
				sub(/:\/\/.*@/, "://<redacted>@", v)
			}
			print k "=" v
		}
	' "$REMIT_DIR/.env"
}

main() {
	[ $# -gt 0 ] || {
		usage >&2
		exit 2
	}
	_cmd=$1
	shift
	case "$_cmd" in
	restart) cmd_restart "$@" ;;
	logs) cmd_logs "$@" ;;
	status) cmd_status "$@" ;;
	update) cmd_update "$@" ;;
	down) cmd_down "$@" ;;
	purge) cmd_purge "$@" ;;
	config) cmd_config "$@" ;;
	cert) cmd_cert "$@" ;;
	probe-host)
		[ $# -eq 1 ] || die "probe-host: needs one origin or hostname"
		probe_host "$1"
		;;
	help | --help | -h) usage ;;
	*)
		printf '%s: unknown command '\''%s'\''\n\n' "$PROG" "$_cmd" >&2
		usage >&2
		exit 2
		;;
	esac
}

# $REMIT_LIB_ONLY lets the test suite source this file and exercise one function
# at a time. It is the only reason it exists; nothing in the deployment sets it.
if [ "${REMIT_LIB_ONLY:-0}" != "1" ]; then
	main "$@"
fi
