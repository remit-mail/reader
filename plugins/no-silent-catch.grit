language js(typescript, jsx);
or {
  `try { $_ } catch ($err) { $body }`,
  `try { $_ } catch ($err: unknown) { $body }`
} where {
  $body <: not contains `throw $_`,
  register_diagnostic(span = $body, message = "A block catch must rethrow (optionally after adding context). For expected-failure recovery, use `.catch()` on the awaited call and branch on the result; for a recoverable sync JSON.parse, use `safeJsonParse(...).catch(...)`; otherwise let it propagate (fail-fast). Block try/catch has no exempt cases — do not suppress this rule. (#1029/#1064)", severity = "error")
}
