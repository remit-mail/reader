# Configuration for the source-built e2e stack (`npm run e2e:dev`) — the same
# deployment shape as the published-image stack in deploy/vps, assembled from
# the worktree instead of from images:
#
#   dovecot         a container, the one deploy/vps/docker-compose.dovecot.yml
#                   defines; there is no reason to run a mail server from source
#   queue-sidecar   packages/queue-sidecar, the same SQS-shaped queue the image
#                   stack runs, over deploy/vps/queues.json
#   migrate         deploy/vps/migrate/run-migrate.ts, DATA_BACKEND=sqlite
#   backend         packages/backend's dev-server, wrapping the same handler
#   imap-worker     packages/imap-worker's queue drainer
#   web             the vite dev server, whose proxy table mirrors the Caddy
#                   routing 1:1 (packages/web-client/vite.config.ts)
#
# What this stack does NOT have is the packaged edge: no Caddy, no APISIX. The
# browser talks to vite, which proxies to the backend directly. That is why the
# gateway spec is image-lane-only — see e2e/src/stack.ts.
#
# Nothing here is secret. Every process binds loopback, the databases are files
# under .remit/e2e-dev, and `npm run e2e:dev:down` destroys all of it.
#
# Ports are deliberately clear of the image lane's (18080/11143) and of the
# local dev stack's (4123/4124/5432/9324), so a source-built run, an image run,
# and a dev session can all be up at once. Four knobs move them —
# E2E_HTTP_PORT, E2E_IMAP_PORT, SERVER_PORT, QUEUE_SIDECAR_PORT — and everything
# addressed by a port is derived from them in e2e-dev-up.sh rather than repeated
# here. `up` refuses to start on a port something else already holds.
#
# On a host that runs several stacks at once, set E2E_DEV_SLOT instead of moving
# the four knobs by hand: it names the lane, and the compose project and the port
# block are derived from it so the runs cannot reach each other's containers.

# -----------------------------------------------------------------------
# Which stack the suite is pointed at. Exported to the suite because it
# matches the E2E_ prefix e2e-test.sh forwards; specs that only apply to the
# packaged deployment read it through e2e/src/stack.ts.
# -----------------------------------------------------------------------
E2E_STACK=dev

# -----------------------------------------------------------------------
# Edge and origin
# -----------------------------------------------------------------------
# The vite dev server is the origin the browser loads and the suite calls.
# PUBLIC_ORIGIN and everything derived from it are appended to the generated
# env by e2e-dev-up.sh, so a port override carries through.
E2E_HTTP_PORT=18090
SERVER_PORT=18091

# -----------------------------------------------------------------------
# Dovecot
# -----------------------------------------------------------------------
# The app is a host process here, not a container on the compose network, so
# it reaches Dovecot through the same published loopback port the suite uses.
# E2E_IMAP_STACK_PORT is what says so; on the image lane it is absent and the
# suite falls back to 143 on the `dovecot` service name.
E2E_IMAP_HOST=127.0.0.1
E2E_IMAP_PORT=11144
E2E_IMAP_STACK_PORT=11144
E2E_IMAP_PASSWORD=e2e-imap-password

# -----------------------------------------------------------------------
# Auth and credential encryption
# -----------------------------------------------------------------------
BETTER_AUTH_SECRET=e2e-better-auth-secret-not-a-secret-32chars
KMS_KEY_ID=FAKE_KMS_KEY_ID
FAKE_KMS_DATAKEY=8AD6A6C8B5E2488FB01796B662DC01AC8AD6A6C8B5E2488FB01796B662DC01AC

# -----------------------------------------------------------------------
# Runtime — SQLite, the same backend the image e2e stack runs
# -----------------------------------------------------------------------
DATA_BACKEND=sqlite
NODE_ENV=development
NODE_NO_WARNINGS=1
# Unused in sqlite mode; the dev-server's startup banner reads them and
# expect-env throws on a missing var.
DYNAMODB_PORT=5434
DYNAMODB_TABLE_NAME=unused-in-sqlite-mode
PG_CONNECTION_URL=postgresql://remit:unused@localhost:5432/remit

# -----------------------------------------------------------------------
# Search
# -----------------------------------------------------------------------
# Keyword search comes from the FTS5 table and triggers the migrator installs,
# which the app's own writes keep current — no worker in the path. The vector
# index is not built on this lane: it would mean downloading the embedding
# model on every PR run, and no spec asserts a semantic result. Nothing
# enqueues to the search-index queue here, which is why its URL is unset.
SEARCH_EMBEDDING_PROVIDER=local
SEARCH_EMBEDDING_MODEL_ID=Xenova/paraphrase-multilingual-MiniLM-L12-v2
SEARCH_EMBEDDING_DIMENSIONS=384

# -----------------------------------------------------------------------
# Queues — the queue-sidecar, run from source over deploy/vps/queues.json
# -----------------------------------------------------------------------
# Only the port is set here; e2e-dev-up.sh derives every SQS_QUEUE_URL_* from
# it, so an override cannot leave the app addressing a sidecar on the old port.
QUEUE_SIDECAR_PORT=19325
QUEUE_SIDECAR_HOST=127.0.0.1
WORKER_MAX_CONCURRENCY=3
WORKER_MAX_CONCURRENCY_BODY=1
BODY_SYNC_CONCURRENCY=3
BODY_SYNC_ENABLED_PARAMETER_NAME=/self-host/Remit/bodySyncEnabled

# -----------------------------------------------------------------------
# AWS SDK placeholders — nothing in this stack talks to AWS.
# -----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=not-a-region
